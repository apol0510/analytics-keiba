---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { readFileSync, existsSync } from 'fs';
import { join } from 'path';

export const prerender = false;

// archiveResultsJra.jsonから全データを取得
const archivePath = join(process.cwd(), 'src', 'data', 'archiveResultsJra.json');
let allMonths: Array<{
  year: string;
  month: string;
  displayMonth: string;
  daysCount: number;
  totalRaces: number;
  totalHitRaces: number;
  hitRate: string;
  totalPayout: number;
  returnRate: string;
}> = [];

try {
  if (existsSync(archivePath)) {
    const fileContent = readFileSync(archivePath, 'utf-8');
    const allData = JSON.parse(fileContent);

    const monthsMap = new Map<string, any[]>();
    allData.forEach((entry: any) => {
      const [year, month] = entry.date.split('-');
      const key = `${year}-${month}`;
      if (!monthsMap.has(key)) {
        monthsMap.set(key, []);
      }
      monthsMap.get(key)!.push(entry);
    });

    monthsMap.forEach((entries, key) => {
      const [year, month] = key.split('-');
      let totalRaces = 0;
      let totalHitRaces = 0;
      let totalBetAmount = 0;
      let totalPayout = 0;

      entries.forEach((entry) => {
        totalRaces += entry.totalRaces;
        totalHitRaces += entry.hitRaces;
        totalBetAmount += entry.betAmount;
        totalPayout += entry.totalPayout;
      });

      const hitRate = totalRaces > 0 ? ((totalHitRaces / totalRaces) * 100).toFixed(1) : '0.0';
      const returnRate = totalBetAmount > 0 ? ((totalPayout / totalBetAmount) * 100).toFixed(1) : '0.0';

      allMonths.push({
        year,
        month,
        displayMonth: `${year}年${month}月`,
        daysCount: entries.length,
        totalRaces,
        totalHitRaces,
        hitRate,
        totalPayout,
        returnRate
      });
    });

    allMonths.sort((a, b) => {
      const keyA = `${a.year}-${a.month}`;
      const keyB = `${b.year}-${b.month}`;
      return keyB.localeCompare(keyA);
    });
  }
} catch (error) {
  console.error('Error loading archive:', error);
}

const pageTitle = '中央競馬（JRA）的中実績アーカイブ';
const pageDescription = '中央競馬（JRA）の全的中実績アーカイブ。月別の的中記録と配当金額を完全公開。';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="archive-jra-hub">
    <div class="page-header">
      <h1 class="title">🏆 的中実績アーカイブ</h1>
      <p class="subtitle">中央競馬（JRA）すべての的中記録を完全公開</p>
      <p class="description">
        パーフェクト的中の日も、不的中の日も、すべて公開。<br>
        透明性と信頼性を最優先にしています。
      </p>
    </div>

    <div class="cta-box">
      <p class="cta-text">
        🎯 これらの実績を生み出したAI予想を、あなたも利用できます
      </p>
      <a href="/pricing/" class="cta-button">プレミアム予想を見る →</a>
    </div>

    {allMonths.length === 0 ? (
      <div class="no-data">
        <p>まだ的中実績データがありません。</p>
      </div>
    ) : (
      <div class="months-grid">
        {allMonths.map((monthData) => (
          <a href={`/archive/jra/${monthData.year}/${monthData.month}/`} class="month-card">
            <div class="month-header">
              <h2 class="month-title">{monthData.displayMonth}</h2>
              {parseFloat(monthData.hitRate) === 100 ? (
                <div class="perfect-highlight">🏆 {monthData.totalHitRaces}/{monthData.totalRaces}的中</div>
              ) : (
                <div class="month-badge">{monthData.daysCount}日開催</div>
              )}
            </div>

            <div class="month-stats-grid">
              <div class="month-stat">
                <div class="month-stat-value">{monthData.hitRate}%</div>
                <div class="month-stat-label">的中率</div>
              </div>
              <div class="month-stat">
                <div class={`month-stat-value ${parseFloat(monthData.returnRate) >= 100 ? 'profit' : 'loss'}`}>{monthData.returnRate}%</div>
                <div class="month-stat-label">回収率</div>
              </div>
              <div class="month-stat">
                <div class="month-stat-value">{monthData.daysCount}日</div>
                <div class="month-stat-label">開催日数</div>
              </div>
              <div class="month-stat">
                <div class="month-stat-value">{monthData.totalHitRaces}/{monthData.totalRaces}</div>
                <div class="month-stat-label">的中レース数</div>
              </div>
              <div class="month-stat">
                <div class="month-stat-value profit">¥{(monthData.totalPayout / 1000).toFixed(0)}K</div>
                <div class="month-stat-label">合計配当</div>
              </div>
            </div>

            <div class="view-details-button">📊 詳細を見る →</div>
          </a>
        ))}
      </div>
    )}

    <div class="back-link">
      <a href="/archive/">← アーカイブトップ</a>
      <a href="/archive/nankan/">南関アーカイブ</a>
      <a href="/pricing/">プレミアム予想</a>
    </div>

    <div class="results-notice">
      <p>※ 掲載されている的中率・収支データは、AIモデルが算出した買い目パターンに基づく理論値です。実際の収支はお客様の購入点数・金額配分により異なります。</p>
      <p>※ 本サービスで提示する買い目は複数パターンの候補を含むため、表示点数と集計上の基準点数が異なる場合があります。</p>
      <p>※ 過去の実績は将来の結果を保証するものではありません。馬券購入は自己責任でお願いいたします。</p>
    </div>
  </div>
</BaseLayout>

<style>
  .archive-jra-hub { padding: 2rem 0 3rem; color: #e2e8f0; }

  .page-header {
    text-align: center;
    margin-bottom: 3rem;
    padding: 2rem;
    background: rgba(30, 41, 59, 0.5);
    border-radius: 16px;
    border: 1px solid rgba(245, 158, 11, 0.3);
  }

  .title { font-size: 2.5rem; font-weight: bold; color: #f59e0b; margin: 0 0 1rem; }
  .subtitle { font-size: 1.2rem; color: #cbd5e1; margin-bottom: 0.5rem; }
  .description { font-size: 1rem; color: #94a3b8; max-width: 600px; margin: 0 auto; }

  .cta-box {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(139, 92, 246, 0.1));
    border: 1px solid rgba(59, 130, 246, 0.3);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    margin-bottom: 3rem;
  }

  .cta-text { font-size: 1.1rem; color: #e2e8f0; margin-bottom: 1rem; }

  .cta-button {
    background: linear-gradient(135deg, #3b82f6, #2563eb);
    color: #fff;
    padding: 1rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    display: inline-block;
    font-weight: bold;
    transition: all 0.3s;
  }
  .cta-button:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(59, 130, 246, 0.4); }

  .months-grid { display: grid; gap: 2rem; }

  .month-card {
    background: rgba(30, 41, 59, 0.8);
    border: 1px solid rgba(100, 116, 139, 0.3);
    border-radius: 16px;
    padding: 2.5rem;
    transition: all 0.3s;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .month-card:hover {
    transform: translateY(-4px);
    border-color: rgba(245, 158, 11, 0.5);
    box-shadow: 0 12px 30px rgba(245, 158, 11, 0.3);
  }

  .month-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid rgba(100, 116, 139, 0.3);
  }

  .month-title { font-size: 2.5rem; font-weight: bold; color: #fbbf24; margin: 0; }

  .perfect-highlight {
    background: linear-gradient(135deg, #10b981, #059669);
    color: #fff;
    padding: 0.8rem 1.5rem;
    border-radius: 12px;
    font-weight: bold;
    font-size: 1.1rem;
  }

  .month-badge {
    background: rgba(245, 158, 11, 0.15);
    color: #fbbf24;
    padding: 0.6rem 1.2rem;
    border-radius: 12px;
    font-weight: bold;
    font-size: 1rem;
    border: 1px solid rgba(245, 158, 11, 0.3);
  }

  .month-stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1.5rem;
  }

  .month-stat {
    text-align: center;
    background: rgba(15, 23, 42, 0.5);
    padding: 1.5rem;
    border-radius: 8px;
    border: 1px solid rgba(59, 130, 246, 0.2);
  }

  .month-stat-value { font-size: 2rem; font-weight: bold; color: #60a5fa; margin-bottom: 0.5rem; }
  .month-stat-value.profit { color: #10b981; }
  .month-stat-value.loss { color: #ef4444; }
  .month-stat-label { font-size: 0.9rem; color: #94a3b8; }

  .view-details-button {
    background: rgba(245, 158, 11, 0.15);
    color: #fbbf24;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-weight: bold;
    font-size: 1rem;
    text-align: center;
    margin-top: 1.5rem;
    transition: all 0.3s;
    display: inline-block;
    width: 100%;
    border: 1px solid rgba(245, 158, 11, 0.3);
  }
  .view-details-button:hover {
    background: rgba(245, 158, 11, 0.25);
    border-color: rgba(245, 158, 11, 0.5);
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(245, 158, 11, 0.3);
  }

  .no-data {
    text-align: center;
    padding: 3rem;
    background: rgba(30, 41, 59, 0.5);
    border-radius: 16px;
    color: #cbd5e1;
  }

  .back-link {
    text-align: center;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(100, 116, 139, 0.3);
  }
  .back-link a {
    color: #60a5fa;
    text-decoration: none;
    font-size: 1rem;
    transition: color 0.3s;
    margin: 0 0.5rem;
  }
  .back-link a:hover { color: #3b82f6; }

  .results-notice { margin-top: 2rem; padding: 1rem 1.25rem; border-top: 1px solid rgba(255, 255, 255, 0.06); }
  .results-notice p { font-size: 0.75rem; color: rgba(148, 163, 184, 0.6); line-height: 1.7; margin: 0; }

  @media (max-width: 768px) {
    .title { font-size: 1.8rem; }
    .month-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .month-title { font-size: 2rem; }
    .month-stats-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
