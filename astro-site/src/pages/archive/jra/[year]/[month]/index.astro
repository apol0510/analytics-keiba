---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import { readFileSync, existsSync, readdirSync } from 'fs';
import { join } from 'path';
import { sortRacesByVenueAndNumber } from '../../../../../utils/sortRaces.js';
import { VENUE_CODE_TO_NAME, synthesizeEntryFromLive, enrichEntryWithLive, isBrokenEntry } from '../../../../../utils/jraLiveHitJudge.js';

export const prerender = false;

const { year, month } = Astro.params;

const archivePath = join(process.cwd(), 'src', 'data', 'archiveResultsJra.json');
let monthData: any[] = [];
let monthStats = {
  totalDays: 0,
  totalRaces: 0,
  totalHitRaces: 0,
  totalBetAmount: 0,
  totalPayout: 0,
  hitRate: '0',
  returnRate: '0',
  hasLive: false,  // 速報モードで暫定表示している日が含まれるか
};

/**
 * archive entry が broken (payout=0) のとき live + 予想 で enrich。
 * util の enrichEntryWithLive() に集約。
 */
function tryEnrichWithLive(entry: any) {
  if (!isBrokenEntry(entry)) return;
  const livePath = join(process.cwd(), 'src', 'data', 'jraLiveResults', `${entry.date}.json`);
  if (!existsSync(livePath)) return;
  let live: any;
  try { live = JSON.parse(readFileSync(livePath, 'utf-8')); } catch { return; }
  const [yyyy, mm] = entry.date.split('-');
  const predPath = join(process.cwd(), 'src', 'data', 'predictions', 'jra', yyyy, mm, `${entry.date}.json`);
  let pred: any = null;
  if (existsSync(predPath)) {
    try { pred = JSON.parse(readFileSync(predPath, 'utf-8')); } catch {}
  }
  enrichEntryWithLive(entry, live, pred);
}

try {
  if (existsSync(archivePath)) {
    const allData = JSON.parse(readFileSync(archivePath, 'utf-8'));
    monthData = allData
      .filter((entry: any) => {
        const [y, m] = entry.date.split('-');
        return y === year && m === month;
      })
      .sort((a: any, b: any) => (b.date || '').localeCompare(a.date || ''));

    // 各エントリを live で enrich (broken なら暫定再計算)
    for (const entry of monthData) {
      tryEnrichWithLive(entry);
      if (entry.live) monthStats.hasLive = true;
    }

    // archive entry が無い日でも live があれば合成して追加
    const liveDir = join(process.cwd(), 'src', 'data', 'jraLiveResults');
    if (existsSync(liveDir)) {
      const liveFiles = readdirSync(liveDir);
      for (const f of liveFiles) {
        const m = f.match(/^(\d{4})-(\d{2})-(\d{2})\.json$/);
        if (!m || m[1] !== year || m[2] !== month) continue;
        const date = `${m[1]}-${m[2]}-${m[3]}`;
        if (monthData.some((e: any) => e.date === date)) continue;
        let live: any, pred: any;
        try { live = JSON.parse(readFileSync(join(liveDir, f), 'utf-8')); } catch { continue; }
        const predPath = join(process.cwd(), 'src', 'data', 'predictions', 'jra', m[1], m[2], `${date}.json`);
        if (existsSync(predPath)) {
          try { pred = JSON.parse(readFileSync(predPath, 'utf-8')); } catch {}
        }
        const synth = synthesizeEntryFromLive(date, live, pred);
        if (synth) {
          monthData.push(synth);
          monthStats.hasLive = true;
        }
      }
      monthData.sort((a: any, b: any) => (b.date || '').localeCompare(a.date || ''));
    }

    monthData.forEach((entry: any) => {
      monthStats.totalDays++;
      monthStats.totalRaces += entry.totalRaces || 0;
      monthStats.totalHitRaces += entry.hitRaces || 0;
      monthStats.totalBetAmount += entry.betAmount || 0;
      monthStats.totalPayout += entry.totalPayout || 0;
    });
    if (monthStats.totalRaces > 0) {
      monthStats.hitRate = ((monthStats.totalHitRaces / monthStats.totalRaces) * 100).toFixed(1);
    }
    if (monthStats.totalBetAmount > 0) {
      monthStats.returnRate = ((monthStats.totalPayout / monthStats.totalBetAmount) * 100).toFixed(1);
    }
  }
} catch (error) {
  console.error('Error loading archive:', error);
}

const pageTitle = monthData.length > 0
  ? `${year}年${parseInt(month)}月 中央競馬 的中実績アーカイブ`
  : '的中実績が見つかりません';

const pageDescription = monthData.length > 0
  ? `${year}年${parseInt(month)}月の中央競馬的中実績。開催日数${monthStats.totalDays}日、月間的中率${monthStats.hitRate}%、月間回収率${monthStats.returnRate}%、月間合計配当¥${monthStats.totalPayout.toLocaleString()}`
  : '中央競馬（JRA）の的中実績アーカイブ';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main class="archive-jra-page">
    <div class="container">
      {monthData.length === 0 ? (
        <div class="no-data">
          <h1>⚠️ データが見つかりません</h1>
          <p>{year}年{parseInt(month)}月の中央競馬的中実績はまだありません。</p>
          <a href="/archive/jra/" class="btn-back">アーカイブトップへ戻る</a>
        </div>
      ) : (
        <>
          <header class="page-header">
            <h1 class="title">🏆 {year}年{parseInt(month)}月 中央競馬 的中実績</h1>
            <p class="subtitle">JRA全レースの的中記録を公開</p>
          </header>

          {/* 月間サマリー */}
          <section class="month-stats">
            <div class="stat-card">
              <div class="stat-value">{monthStats.totalDays}日</div>
              <div class="stat-label">開催日数</div>
            </div>
            <div class="stat-card">
              <div class="stat-value">{monthStats.hitRate}%</div>
              <div class="stat-label">月間的中率</div>
            </div>
            <div class="stat-card">
              <div class={`stat-value ${parseFloat(monthStats.returnRate) >= 100 ? 'profit' : 'loss'}`}>
                {monthStats.returnRate}%
              </div>
              <div class="stat-label">月間回収率</div>
            </div>
            <div class="stat-card">
              <div class="stat-value profit">¥{monthStats.totalPayout.toLocaleString()}</div>
              <div class="stat-label">月間合計配当</div>
            </div>
            <div class="stat-card">
              <div class="stat-value">{monthStats.totalHitRaces}/{monthStats.totalRaces}</div>
              <div class="stat-label">的中レース数</div>
            </div>
          </section>

          {/* 買い目点数に関する注記（intelligence 方式に合わせて点数は非公開） */}
          <p class="rule-note">※買い目は内部ルールに基づき調整しています</p>

          {/* 日別アーカイブ */}
          {monthData.map((dayData: any) => {
            const [, , day] = dayData.date.split('-');
            const venueLabel = Array.isArray(dayData.venues) && dayData.venues.length > 0
              ? dayData.venues.join('・')
              : dayData.venue;
            // 全レースをラウンドロビン順にソートしてから的中のみ抽出
            const hitRaces = sortRacesByVenueAndNumber(dayData.races || [], dayData.venues)
              .filter((race: any) => race.isHit);

            return (
              <section class="day-section">
                <div class="day-header">
                  <h2 class="day-title">
                    <span class="day-date">{parseInt(month)}月{parseInt(day)}日</span>
                    <span class="day-venue">{venueLabel}</span>
                    {dayData.live && <span class="live-badge">速報</span>}
                  </h2>
                  <div class="perfect-badge">🏆 {dayData.live ? '暫定的中' : '的中'} {dayData.hitRaces}/{dayData.totalRaces}</div>
                </div>

                <div class="day-summary">
                  <div class="summary-item">
                    📊 的中率: <span class="summary-value">{dayData.hitRate}%</span>
                  </div>
                  {!dayData.live && (
                    <>
                      <div class="summary-item">
                        📈 回収率: <span class={`summary-value ${dayData.returnRate >= 100 ? 'profit' : 'loss'}`}>{dayData.returnRate}%</span>
                      </div>
                      <div class="summary-item">
                        💰 合計配当: <span class="summary-value profit">¥{dayData.totalPayout.toLocaleString()}</span>
                      </div>
                    </>
                  )}
                </div>

                <div class="races-grid">
                  {hitRaces.length === 0 ? (
                    <div class="no-hits">的中レースなし</div>
                  ) : (
                    hitRaces.map((race: any) => (
                      <div class="race-card">
                        <div class="race-info">
                          <div class="race-number">{race.venue}{race.raceNumber}R</div>
                          <div class="race-name">{race.raceName}</div>
                        </div>
                        <div class="race-result">
                          <div class="hit-badge">✅ 的中</div>
                          {race.umatan?.payout > 0 && (
                            <div class="payout">¥{race.umatan.payout.toLocaleString()}</div>
                          )}
                        </div>
                      </div>
                    ))
                  )}
                </div>

                <div class="day-footer">
                  <a href={`/results/${year}/${month}/${day}`} class="day-detail-link">詳細を見る →</a>
                </div>
              </section>
            );
          })}

          <footer class="page-footer">
            <a href="/archive/jra/" class="btn-back">← JRAアーカイブトップ</a>
            <a href="/pricing/" class="btn-primary">💎 プレミアム予想を見る</a>
          </footer>
        </>
      )}
    </div>
  </main>
</BaseLayout>

<style lang="scss">
  .archive-jra-page {
    min-height: 100vh;
    padding: 2rem 1rem 3rem;
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    color: #e2e8f0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* データなし */
  .no-data {
    text-align: center;
    padding: 3rem 1.5rem;
    background: rgba(30, 41, 59, 0.8);
    border: 1px solid rgba(100, 116, 139, 0.3);
    border-radius: 16px;

    h1 { font-size: 2rem; margin-bottom: 1rem; color: #fbbf24; }
    p { color: #cbd5e1; margin-bottom: 1.5rem; }
  }

  /* ヘッダー */
  .page-header {
    text-align: center;
    margin-bottom: 2.5rem;
    padding: 2rem;
    background: rgba(30, 41, 59, 0.5);
    border: 1px solid rgba(245, 158, 11, 0.3);
    border-radius: 16px;

    .title {
      font-size: 2.25rem;
      font-weight: 800;
      color: #f59e0b;
      margin-bottom: 0.5rem;
    }

    .subtitle {
      font-size: 1.05rem;
      color: #cbd5e1;
    }
  }

  /* 買い目ルール注記 (点数非公開方針) */
  .rule-note {
    text-align: center;
    font-size: 0.85rem;
    color: #94a3b8;
    margin: 0 0 2rem;
    opacity: 0.85;
  }

  /* 月間サマリーカード */
  .month-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .stat-card {
    background: rgba(30, 41, 59, 0.8);
    border: 1px solid rgba(59, 130, 246, 0.3);
    border-radius: 12px;
    padding: 1.5rem 1rem;
    text-align: center;

    .stat-value {
      font-size: 2rem;
      font-weight: 800;
      color: #60a5fa;
      margin-bottom: 0.35rem;
      line-height: 1.2;
      word-break: break-all;

      &.profit { color: #10b981; }
      &.loss { color: #ef4444; }
      &.pending {
        color: #94a3b8;
        font-size: 1.25rem;
        font-weight: 600;
      }
    }

    .stat-label {
      font-size: 0.9rem;
      color: #94a3b8;
    }
  }

  /* 日別セクション */
  .day-section {
    background: rgba(30, 41, 59, 0.8);
    border: 1px solid rgba(100, 116, 139, 0.3);
    border-radius: 16px;
    padding: 2rem;
    margin-bottom: 2rem;
  }

  .day-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(100, 116, 139, 0.3);
    flex-wrap: wrap;
  }

  .day-title {
    font-size: 1.6rem;
    font-weight: 800;
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin: 0;

    .day-date { color: #fbbf24; }
    .day-venue {
      font-size: 1.1rem;
      font-weight: 600;
      color: #cbd5e1;
    }
  }

  .perfect-badge {
    background: linear-gradient(135deg, #10b981, #059669);
    color: #fff;
    padding: 0.55rem 1.1rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.95rem;
    white-space: nowrap;
  }

  .day-summary {
    display: flex;
    gap: 1.75rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;

    .summary-item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      color: #cbd5e1;
      font-size: 0.95rem;
    }

    .summary-value {
      color: #60a5fa;
      font-weight: 700;

      &.profit { color: #10b981; }
      &.loss { color: #ef4444; }
      &.pending {
        color: #94a3b8;
        font-weight: 600;
      }
    }
  }

  /* 速報バッジ */
  .live-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.7rem;
    background: linear-gradient(135deg, rgba(251, 191, 36, 0.25) 0%, rgba(245, 158, 11, 0.15) 100%);
    border: 1px solid rgba(251, 191, 36, 0.55);
    border-radius: 999px;
    color: #fbbf24;
    font-weight: 800;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    box-shadow: 0 0 8px rgba(251, 191, 36, 0.25);
    margin-left: 0.5rem;
  }

  /* レース一覧 */
  .races-grid {
    display: grid;
    gap: 0.85rem;
  }

  .race-card {
    background: linear-gradient(90deg, rgba(16, 185, 129, 0.12) 0%, rgba(15, 23, 42, 0.6) 100%);
    border: 1px solid rgba(100, 116, 139, 0.3);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    transition: all 0.2s ease;

    &:hover {
      border-color: rgba(16, 185, 129, 0.5);
      background: linear-gradient(90deg, rgba(16, 185, 129, 0.18) 0%, rgba(15, 23, 42, 0.75) 100%);
    }
  }

  .race-info {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex: 1;
    min-width: 0;

    .race-number {
      font-size: 1.05rem;
      font-weight: 800;
      color: #fbbf24;
      min-width: 5.5rem;
      white-space: nowrap;
    }

    .race-name {
      color: #cbd5e1;
      font-size: 0.95rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
  }

  .race-result {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    flex-shrink: 0;

    .hit-badge {
      background: rgba(16, 185, 129, 0.2);
      color: #10b981;
      padding: 0.35rem 0.75rem;
      border-radius: 6px;
      font-weight: 700;
      font-size: 0.85rem;
      border: 1px solid rgba(16, 185, 129, 0.35);
      white-space: nowrap;
    }

    .bet-info {
      color: #c4b5fd;
      font-size: 0.9rem;
      font-weight: 600;
      white-space: nowrap;
    }

    .payout {
      font-size: 1.15rem;
      font-weight: 800;
      color: #fbbf24;
      white-space: nowrap;
      min-width: 5rem;
      text-align: right;
    }
  }

  .no-hits {
    padding: 1.25rem;
    text-align: center;
    color: #94a3b8;
    font-size: 0.9rem;
    background: rgba(15, 23, 42, 0.4);
    border-radius: 8px;
  }

  .day-footer {
    margin-top: 1.25rem;
    text-align: right;

    .day-detail-link {
      color: #60a5fa;
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 600;

      &:hover { color: #93c5fd; }
    }
  }

  /* ページフッター */
  .page-footer {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(100, 116, 139, 0.3);
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-back, .btn-primary {
    display: inline-block;
    padding: 0.8rem 1.6rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.2s ease;
  }

  .btn-back {
    background: rgba(100, 116, 139, 0.25);
    color: #cbd5e1;
    border: 1px solid rgba(100, 116, 139, 0.5);

    &:hover { background: rgba(100, 116, 139, 0.4); }
  }

  .btn-primary {
    background: linear-gradient(135deg, #3b82f6, #1d4ed8);
    color: #fff;

    &:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(59, 130, 246, 0.4); }
  }

  /* レスポンシブ */
  @media (max-width: 768px) {
    .page-header .title { font-size: 1.6rem; }
    .stat-card .stat-value { font-size: 1.5rem; }
    .day-section { padding: 1.25rem; }
    .day-title { font-size: 1.25rem; }
    .day-title .day-venue { font-size: 0.95rem; }

    .race-card {
      flex-direction: column;
      align-items: stretch;
      gap: 0.6rem;
    }

    .race-info {
      flex-direction: column;
      gap: 0.2rem;

      .race-number { min-width: auto; }
      .race-name { white-space: normal; }
    }

    .race-result {
      justify-content: space-between;
      gap: 0.5rem;

      .payout { min-width: auto; }
    }
  }
</style>
