---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readFileSync, existsSync } from 'fs';
import { join } from 'path';

export const prerender = false;

function readLatestMonth(jsonPath: string): { year: string; month: string } | null {
  if (!existsSync(jsonPath)) return null;
  try {
    const data = JSON.parse(readFileSync(jsonPath, 'utf-8'));
    if (!Array.isArray(data) || data.length === 0) return null;
    const dates = data.map((e: any) => e?.date).filter(Boolean).sort().reverse() as string[];
    if (dates.length === 0) return null;
    const [year, month] = dates[0].split('-');
    return { year, month };
  } catch {
    return null;
  }
}

const jraLatest = readLatestMonth(join(process.cwd(), 'src', 'data', 'archiveResultsJra.json'));
const nankanLatest = readLatestMonth(join(process.cwd(), 'src', 'data', 'archiveResults.json'));

const jraLatestHref = jraLatest ? `/archive/jra/${jraLatest.year}/${jraLatest.month}/` : '/archive/jra/';
const nankanLatestHref = nankanLatest ? `/archive/nankan/${nankanLatest.year}/${nankanLatest.month}/` : '/archive/nankan/';

const formatLatestLabel = (m: { year: string; month: string } | null) =>
  m ? `${m.year}年${parseInt(m.month, 10)}月` : '最新月';

const pageTitle = '的中実績アーカイブ';
const pageDescription = '中央競馬（JRA）と南関競馬の的中実績アーカイブ。月別・日別の予想結果と配当を全件アーカイブ。AI予想モデルの判定精度を実データでご確認いただけます。';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="archive-hub">
    <div class="page-header">
      <h1 class="page-title">🏆 的中実績アーカイブ</h1>
      <p class="page-subtitle">中央競馬（JRA）と南関競馬の的中記録</p>
      <p class="page-description">
        AI予想モデルの判定精度を実データでご確認いただけます。<br>
        月別・日別の予想結果と配当をすべてアーカイブしています。
      </p>
    </div>

    <div class="category-grid">
      <div class="category-card jra">
        <div class="card-header">
          <span class="card-icon">🏇</span>
          <span class="card-title">中央競馬（JRA）</span>
        </div>
        <p class="card-summary">
          東京・中山・京都・阪神を中心に、JRA全10場の的中実績を月別・日別に公開。重賞レースを含む全レースをアーカイブ。
        </p>
        <div class="card-venues">
          <span class="venue-tag">東京</span>
          <span class="venue-tag">中山</span>
          <span class="venue-tag">京都</span>
          <span class="venue-tag">阪神</span>
          <span class="venue-tag">中京・新潟・福島・小倉・札幌・函館</span>
        </div>
        <div class="card-actions">
          <a href="/archive/jra/" class="btn-primary">📊 JRAアーカイブを見る</a>
          {jraLatest && (
            <a href={jraLatestHref} class="btn-secondary">最新開催（{formatLatestLabel(jraLatest)}）を見る</a>
          )}
        </div>
      </div>

      <div class="category-card nankan">
        <div class="card-header">
          <span class="card-icon">🐎</span>
          <span class="card-title">南関競馬</span>
        </div>
        <p class="card-summary">
          大井・川崎・船橋・浦和の南関4場の的中実績を年別・月別・日別に公開。マリーンカップ・日本テレビ盃等の重賞レースを含むアーカイブ。
        </p>
        <div class="card-venues">
          <span class="venue-tag">大井</span>
          <span class="venue-tag">川崎</span>
          <span class="venue-tag">船橋</span>
          <span class="venue-tag">浦和</span>
        </div>
        <div class="card-actions">
          <a href="/archive/nankan/" class="btn-primary">📊 南関アーカイブを見る</a>
          {nankanLatest && (
            <a href={nankanLatestHref} class="btn-secondary">最新開催（{formatLatestLabel(nankanLatest)}）を見る</a>
          )}
        </div>
      </div>
    </div>

    <div class="back-link">
      <a href="/">← トップページ</a>
      <a href="/free-prediction/">無料予想</a>
      <a href="/pricing/">プレミアム予想</a>
    </div>

    <div class="results-notice">
      <p>※ 掲載されている的中率・収支データは、AIモデルが算出した買い目パターンに基づく理論値です。実際の収支はお客様の購入点数・金額配分により異なります。</p>
      <p>※ 本サービスで提示する買い目は複数パターンの候補を含むため、表示点数と集計上の基準点数が異なる場合があります。</p>
      <p>※ 過去の実績は将来の結果を保証するものではありません。馬券購入は自己責任でお願いいたします。</p>
    </div>
  </div>
</BaseLayout>

<style>
  .archive-hub {
    padding: 2rem 0 3rem;
    color: #e2e8f0;
  }

  .page-header {
    text-align: center;
    margin-bottom: 3rem;
    padding: 2.5rem 2rem;
    background: rgba(30, 41, 59, 0.5);
    border-radius: 16px;
    border: 1px solid rgba(245, 158, 11, 0.3);
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: bold;
    background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 50%, #60a5fa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0 0 1rem;
  }

  .page-subtitle { font-size: 1.2rem; color: #cbd5e1; margin-bottom: 0.5rem; }
  .page-description { font-size: 1rem; color: #94a3b8; max-width: 640px; margin: 0 auto; line-height: 1.7; }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .category-card {
    background: rgba(30, 41, 59, 0.8);
    border: 1px solid rgba(100, 116, 139, 0.3);
    border-radius: 16px;
    padding: 2.5rem;
    transition: all 0.3s;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .category-card.jra { border-color: rgba(59, 130, 246, 0.35); }
  .category-card.jra:hover { transform: translateY(-4px); border-color: rgba(59, 130, 246, 0.6); box-shadow: 0 12px 30px rgba(59, 130, 246, 0.3); }
  .category-card.nankan { border-color: rgba(245, 158, 11, 0.35); }
  .category-card.nankan:hover { transform: translateY(-4px); border-color: rgba(245, 158, 11, 0.6); box-shadow: 0 12px 30px rgba(245, 158, 11, 0.3); }

  .card-header { display: flex; align-items: center; gap: 0.75rem; }
  .card-icon { font-size: 2.25rem; }
  .card-title { font-size: 1.75rem; font-weight: 800; }
  .category-card.jra .card-title { color: #60a5fa; }
  .category-card.nankan .card-title { color: #fbbf24; }

  .card-summary { color: #cbd5e1; font-size: 1rem; line-height: 1.7; }
  .card-venues { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .venue-tag {
    font-size: 0.85rem;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.6);
    color: #cbd5e1;
    border: 1px solid rgba(100, 116, 139, 0.4);
  }

  .card-actions { display: flex; flex-direction: column; gap: 0.6rem; margin-top: auto; padding-top: 0.5rem; }

  .btn-primary, .btn-secondary {
    display: inline-block;
    text-align: center;
    padding: 0.85rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.3s;
    border: 1px solid transparent;
  }

  .category-card.jra .btn-primary { background: linear-gradient(135deg, #3b82f6, #2563eb); color: #fff; }
  .category-card.jra .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(59, 130, 246, 0.4); }
  .category-card.nankan .btn-primary { background: linear-gradient(135deg, #f59e0b, #d97706); color: #fff; }
  .category-card.nankan .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(245, 158, 11, 0.4); }
  .btn-secondary { background: rgba(15, 23, 42, 0.6); color: #cbd5e1; border-color: rgba(100, 116, 139, 0.4); }
  .btn-secondary:hover { background: rgba(15, 23, 42, 0.85); border-color: rgba(148, 163, 184, 0.6); }

  .back-link { text-align: center; margin-top: 2rem; padding-top: 2rem; border-top: 1px solid rgba(100, 116, 139, 0.3); }
  .back-link a { color: #60a5fa; text-decoration: none; font-size: 1rem; margin: 0 0.5rem; }
  .back-link a:hover { color: #3b82f6; }

  .results-notice { margin-top: 2rem; padding: 1rem 1.25rem; border-top: 1px solid rgba(255, 255, 255, 0.06); }
  .results-notice p { font-size: 0.75rem; color: rgba(148, 163, 184, 0.6); line-height: 1.7; margin: 0; }

  @media (max-width: 768px) {
    .page-title { font-size: 1.8rem; }
    .category-grid { grid-template-columns: 1fr; gap: 1.5rem; }
    .card-title { font-size: 1.5rem; }
  }
</style>
