                alert('整形するHTMLコードを入力してください');
                return;
            }
            
            try {
                // HTMLを整形する
                let formatted = html
                    // タグの前後に改行を追加
                    .replace(/></g, '>\n<')
                    // 開始タグの後に改行
                    .replace(/(<\/?)(\w+)([^>]*>)/g, '$1$2$3\n')
                    // 閉じタグの前に改行
                    .replace(/\n<\//g, '\n</')
                    // 余分な改行を削除
                    .replace(/\n\s*\n/g, '\n')
                    // インライン要素は同じ行に保持
