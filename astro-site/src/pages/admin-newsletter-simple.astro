// シンプルなメルマガ配信管理画面
import BaseLayout from '../layouts/BaseLayout.astro';

// サーバーサイドで顧客統計を取得
let customerStats = {
    total: 0,
    free: 0,  // 旧: 全Free会員（互換性のため保持）
    freeRegistered: 0,  // 🆕 無料登録済み（~700名）
    freeUnregistered: 0,  // 🆕 未登録（~15,000名）
    standard: 0,
    premium: 0,
    premiumSanrenpuku: 0,
    premiumCombo: 0,
    paidTotal: 0,  // 有料版合計
    test: 0
};

let debugInfo = {
    hasApiKey: false,
    hasBaseId: false,
    apiCallSuccess: false,
    recordCount: 0,
    errorMessage: '',
    sampleRecords: [],
    uniquePlanValues: new Set(),
    planCounts: {}
};

try {
    const AIRTABLE_API_KEY = import.meta.env.AIRTABLE_API_KEY;
    const AIRTABLE_BASE_ID = import.meta.env.AIRTABLE_BASE_ID;

    debugInfo.hasApiKey = !!AIRTABLE_API_KEY;
    debugInfo.hasBaseId = !!AIRTABLE_BASE_ID;

    if (AIRTABLE_API_KEY && AIRTABLE_BASE_ID) {
        // 🔄 ページネーション対応: 全レコードを取得
        let allRecords = [];
        let offset = null;
        let pageCount = 0;

        do {
            pageCount++;
            let url = `https://api.airtable.com/v0/${AIRTABLE_BASE_ID}/Customers?pageSize=100`;
            if (offset) {
                url += `&offset=${offset}`;
            }

            const response = await fetch(url, {
                headers: {
                    'Authorization': `Bearer ${AIRTABLE_API_KEY}`,
                    'Content-Type': 'application/json'
                }
            });

            debugInfo.apiCallSuccess = response.ok;

            if (response.ok) {
                const data = await response.json();
                allRecords.push(...data.records);
                offset = data.offset; // 次のページのオフセット

                console.log(`📄 ページ ${pageCount}: ${data.records.length}件取得, 累計: ${allRecords.length}件`);
            } else {
                debugInfo.errorMessage = `API Error: ${response.status} ${response.statusText}`;
                break;
            }
        } while (offset); // offsetが存在する限り継続

        debugInfo.recordCount = allRecords.length;
        console.log(`✅ 全データ取得完了: 合計 ${allRecords.length}件 (${pageCount}ページ)`);

        if (allRecords.length > 0) {

            allRecords.forEach((record, index) => {
                customerStats.total++;

                // フィールド名の確認（デバッグ用）
                const fields = record.fields;

                // 全てのレコードを詳細分析（最初の10件）
                const planField = fields['プラン'] || fields['Plan'] || fields['plan'] || fields['PLAN'] ||
                                 fields['Subscription'] || fields['会員種別'];

                if (debugInfo.sampleRecords.length < 10) {
                    debugInfo.sampleRecords.push({
                        index: index + 1,
                        fields: Object.keys(fields),
                        planField: planField,
                        email: fields['Email'] || fields['email'] || 'unknown'
                    });
                }

                // 可能なプランフィールド名を確認（デフォルト値は設定しない）
                const planValue = fields['プラン'] || fields['Plan'] || fields['plan'] || fields['PLAN'] ||
                                 fields['Subscription'] || fields['会員種別'];

                // 全てのプラン値を収集
                debugInfo.uniquePlanValues.add(planValue);
                if (debugInfo.planCounts[planValue]) {
                    debugInfo.planCounts[planValue]++;
                } else {
                    debugInfo.planCounts[planValue] = 1;
                }

                // null/undefined/空文字の場合は事前にFree判定（登録済み/未登録を区別）
                if (!planValue || planValue === null || planValue === undefined || planValue === '') {
                    // 🔍 氏名フィールドをチェックして登録済み/未登録を判定
                    const nameField = fields['氏名'] || fields['Name'] || fields['name'] || '';
                    const isUnregistered = String(nameField).includes('未登録');

                    if (isUnregistered) {
                        customerStats.freeUnregistered++;
                        console.log(`空のプラン値 + 未登録: "${planValue}" -> 未登録Free (氏名: ${nameField})`);
                    } else {
                        customerStats.freeRegistered++;
                        console.log(`空のプラン値 + 登録済み: "${planValue}" -> 登録済みFree (氏名: ${nameField})`);
                    }

                    customerStats.free++;  // 互換性のため合計もカウント
                    return; // forEachではcontinueの代わりにreturnを使用
                }

                const plan = String(planValue).toLowerCase().trim();

                // Airtableの実際のプラン値に基づく正確な判定ロジック
                if (plan === 'standard' || plan === 'スタンダード') {
                    customerStats.standard++;
                    console.log(`Standard判定: "${planValue}"`);
                } else if (plan === 'premium combo' || plan === 'premiumcombo' || plan === 'プレミアムコンボ') {
                    customerStats.premiumCombo++;
                    console.log(`Premium Combo判定: "${planValue}"`);
                } else if (plan === 'premium sanrenpuku' || plan === 'premiumsanrenpuku' || plan === 'プレミアム三連複') {
                    customerStats.premiumSanrenpuku++;
                    console.log(`Premium Sanrenpuku判定: "${planValue}"`);
                } else if (plan === 'premium' || plan === 'プレミアム' || plan === 'premium predictions' ||
                           plan === 'premium plus' || plan === 'premiumplus' || plan === 'プレミアムプラス') {
                    customerStats.premium++;
                    console.log(`Premium判定: "${planValue}"`);
                } else if (plan === 'test' || plan === 'テスト') {
                    customerStats.test++;
                    console.log(`Test判定: "${planValue}"`);
                } else if (plan === 'free' || plan === 'フリー') {
                    // 🔍 プラン='Free'でも氏名で登録済み/未登録を区別
                    const nameField = fields['氏名'] || fields['Name'] || fields['name'] || '';
                    const isUnregistered = String(nameField).includes('未登録');

                    if (isUnregistered) {
                        customerStats.freeUnregistered++;
                        console.log(`Free判定 + 未登録: "${planValue}" (氏名: ${nameField})`);
                    } else {
                        customerStats.freeRegistered++;
                        console.log(`Free判定 + 登録済み: "${planValue}" (氏名: ${nameField})`);
                    }

                    customerStats.free++;  // 互換性のため合計もカウント
                } else {
                    // 未分類の場合も詳細ログに記録してからFreeに分類（登録済み/未登録を区別）
                    const nameField = fields['氏名'] || fields['Name'] || fields['name'] || '';
                    const isUnregistered = String(nameField).includes('未登録');

                    if (isUnregistered) {
                        customerStats.freeUnregistered++;
                        console.log(`未分類プラン値 + 未登録: "${planValue}" (type: ${typeof planValue}) -> 未登録Free扱い (氏名: ${nameField})`);
                    } else {
                        customerStats.freeRegistered++;
                        console.log(`未分類プラン値 + 登録済み: "${planValue}" (type: ${typeof planValue}) -> 登録済みFree扱い (氏名: ${nameField})`);
                    }

                    customerStats.free++;  // 互換性のため合計もカウント
                }
            });

            // 有料版合計を計算
            customerStats.paidTotal = customerStats.standard + customerStats.premium +
                                      customerStats.premiumSanrenpuku + customerStats.premiumCombo;
            console.log(`💰 有料版合計: ${customerStats.paidTotal}名 (Standard: ${customerStats.standard}, Premium: ${customerStats.premium}, Sanrenpuku: ${customerStats.premiumSanrenpuku}, Combo: ${customerStats.premiumCombo})`);
        }
    } else {
        debugInfo.errorMessage = 'Missing API credentials';
    }
} catch (error) {
    debugInfo.errorMessage = error.message;
}

// ✅ Set を配列に変換（JSON シリアライズ可能にする）
debugInfo.uniquePlanValues = Array.from(debugInfo.uniquePlanValues);
---

<BaseLayout title="メルマガ配信">
