        // ==========================================
        // 📊 サマリーダッシュボード機能
        // ==========================================

        async function loadSummaryData() {
            console.log('📊 サマリーデータ読み込み中...');

            try {
                // 今月の配信数を取得（ScheduledEmails SENT + EXECUTING）
                const historyResponse = await fetch('/.netlify/functions/get-scheduled-jobs?status=all');
                if (historyResponse.ok) {
                    const historyData = await historyResponse.json();
                    const now = new Date();
                    const thisMonthStart = new Date(now.getFullYear(), now.getMonth(), 1);

                    const thisMonthJobs = historyData.records?.filter(record => {
                        const sentAt = record.fields.SentAt || record.fields.CreatedAt;
                        if (!sentAt) return false;
                        const jobDate = new Date(sentAt);
                        return jobDate >= thisMonthStart && (record.fields.Status === 'SENT' || record.fields.Status === 'EXECUTING');
                    }) || [];

                    document.getElementById('monthlyDeliveries').textContent = thisMonthJobs.length;
                }

                // 今月のブロック数を取得（EmailBlacklist）
                const blacklistResponse = await fetch('/.netlify/functions/domain-protection?action=get-blacklist');
                if (blacklistResponse.ok) {
                    const blacklistData = await blacklistResponse.json();
                    const now = new Date();
                    const thisMonthStart = new Date(now.getFullYear(), now.getMonth(), 1);

                    const thisMonthBlocks = blacklistData.records?.filter(record => {
                        const blockedAt = record.fields.BlockedAt;
                        if (!blockedAt) return false;
                        const blockDate = new Date(blockedAt);
                        return blockDate >= thisMonthStart;
                    }) || [];

                    document.getElementById('monthlyBlocks').textContent = thisMonthBlocks.length;
                }

                // 予約配信待ちを取得（PENDING）
                const pendingResponse = await fetch('/.netlify/functions/get-scheduled-jobs?status=PENDING');
                if (pendingResponse.ok) {
                    const pendingData = await pendingResponse.json();
                    document.getElementById('pendingJobs').textContent = pendingData.stats?.pending || pendingData.jobs?.length || 0;
                }

                console.log('✅ サマリーデータ読み込み完了');
            } catch (error) {
                console.error('❌ サマリーデータ読み込みエラー:', error);
                document.getElementById('monthlyDeliveries').textContent = 'エラー';
                document.getElementById('monthlyBlocks').textContent = 'エラー';
                document.getElementById('pendingJobs').textContent = 'エラー';
            }
        }

        document.getElementById('refreshSummaryBtn').addEventListener('click', loadSummaryData);

        // ==========================================
        // 🔔 アラート・通知機能
        // ==========================================

        async function loadAlerts() {
            console.log('🔔 アラート読み込み中...');

            const container = document.getElementById('alertContainer');
            const alerts = [];

            try {
                // 過去24時間のバウンス数チェック
                const blacklistResponse = await fetch('/.netlify/functions/domain-protection?action=get-blacklist');
                if (blacklistResponse.ok) {
                    const blacklistData = await blacklistResponse.json();
                    const oneDayAgo = new Date(Date.now() - 24 * 60 * 60 * 1000);

                    const recentBounces = blacklistData.records?.filter(record => {
                        const lastBounce = record.fields.LastBounceDate;
                        if (!lastBounce) return false;
                        return new Date(lastBounce) >= oneDayAgo;
                    }) || [];

                    if (recentBounces.length >= 5) {
                        alerts.push({
                            type: 'warning',
                            icon: '⚠️',
                            title: `過去24時間で${recentBounces.length}件のバウンスが発生しました`,
                            message: 'メールアドレスの品質を確認してください。'
                        });
                    }

                    // 新規ブロックされたドメイン（過去7日間）
                    const sevenDaysAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000);
                    const newBlocks = blacklistData.records?.filter(record => {
                        const blockedAt = record.fields.BlockedAt;
                        if (!blockedAt) return false;
                        return new Date(blockedAt) >= sevenDaysAgo;
                    }) || [];

                    if (newBlocks.length > 0) {
                        const domainNames = newBlocks.map(r => r.fields.Domain).join(', ');
                        alerts.push({
                            type: 'error',
                            icon: '🚨',
                            title: `新規ブロックされたドメイン: ${newBlocks.length}件`,
                            message: `${domainNames.substring(0, 50)}${domainNames.length > 50 ? '...' : ''}`
                        });
                    }
                }

                // 予約配信の確認
                const pendingResponse = await fetch('/.netlify/functions/get-scheduled-jobs?status=pending');
                if (pendingResponse.ok) {
                    const pendingData = await pendingResponse.json();
                    const now = new Date();
                    const oneHourLater = new Date(now.getTime() + 60 * 60 * 1000);

                    const upcomingJobs = pendingData.records?.filter(record => {
                        const scheduledFor = new Date(record.fields.ScheduledFor);
                        return scheduledFor <= oneHourLater && scheduledFor > now;
                    }) || [];

                    if (upcomingJobs.length > 0) {
                        alerts.push({
                            type: 'info',
                            icon: '📅',
                            title: `1時間以内に${upcomingJobs.length}件の予約配信があります`,
                            message: '配信内容に問題がないか確認してください。'
                        });
                    }
                }

                // アラート表示
                if (alerts.length === 0) {
                    container.innerHTML = `
                        <div class="alert-box alert-info">
                            <div class="alert-icon">✅</div>
                            <div class="alert-content">
                                <div class="alert-title">問題なし</div>
                                <div class="alert-message">現在、注意すべきアラートはありません。</div>
                            </div>
                        </div>
                    `;
                } else {
                    container.innerHTML = alerts.map(alert => `
                        <div class="alert-box alert-${alert.type}">
                            <div class="alert-icon">${alert.icon}</div>
                            <div class="alert-content">
                                <div class="alert-title">${alert.title}</div>
                                <div class="alert-message">${alert.message}</div>
                            </div>
                        </div>
                    `).join('');
                }

                console.log('✅ アラート読み込み完了');
            } catch (error) {
                console.error('❌ アラート読み込みエラー:', error);
                container.innerHTML = `
                    <div class="alert-box alert-error">
                        <div class="alert-icon">❌</div>
                        <div class="alert-content">
                            <div class="alert-title">エラー</div>
                            <div class="alert-message">アラートデータの読み込みに失敗しました。</div>
                        </div>
                    </div>
                `;
            }
        }

        document.getElementById('refreshAlertsBtn').addEventListener('click', loadAlerts);

        // ==========================================
        // 📜 配信履歴機能
        // ==========================================

        async function loadHistory(filterStatus = 'all') {
            console.log('📜 配信履歴読み込み中...', filterStatus);

            const tbody = document.getElementById('historyTableBody');
            tbody.innerHTML = '<tr><td colspan="5" style="text-align: center; padding: 20px;">読み込み中...</td></tr>';

            try {
                const response = await fetch(`/.netlify/functions/get-scheduled-jobs?status=${filterStatus}`);
                if (!response.ok) {
                    throw new Error('履歴データの取得に失敗しました');
                }

                const data = await response.json();
                const records = data.records || [];

                if (records.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="5" style="text-align: center; padding: 40px; color: #6b7280;">履歴データがありません</td></tr>';
                    return;
                }

                // 日付順にソート（新しい順）
                records.sort((a, b) => {
                    const dateA = new Date(a.fields.ScheduledFor || a.fields.CreatedAt);
                    const dateB = new Date(b.fields.ScheduledFor || b.fields.CreatedAt);
                    return dateB - dateA;
                });

                tbody.innerHTML = records.slice(0, 50).map(record => {
                    const fields = record.fields;
                    const status = fields.Status || 'UNKNOWN';
                    const scheduledFor = new Date(fields.ScheduledFor || fields.CreatedAt);
                    const recipientCount = fields.Recipients ? fields.Recipients.split(',').length : 0;

                    // ステータスバッジ
                    let statusBadge = '';
                    if (status === 'SENT') {
                        statusBadge = '<span class="status-badge status-sent">送信済み</span>';
                    } else if (status === 'PENDING' || status === 'EXECUTING') {
                        statusBadge = '<span class="status-badge status-pending">実行待ち</span>';
                    } else if (status === 'FAILED') {
                        statusBadge = '<span class="status-badge status-failed">失敗</span>';
                    }

                    // 日時フォーマット
                    const dateStr = scheduledFor.toLocaleString('ja-JP', {
                        year: 'numeric',
                        month: '2-digit',
                        day: '2-digit',
                        hour: '2-digit',
                        minute: '2-digit'
                    });

                    return `
                        <tr>
                            <td>${dateStr}</td>
                            <td style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                ${fields.Subject || '（件名なし）'}
                            </td>
                            <td style="text-align: center;">${recipientCount}名</td>
                            <td>${statusBadge}</td>
                            <td style="font-size: 12px; color: #6b7280;">${fields.JobId || '-'}</td>
                        </tr>
                    `;
                }).join('');

                console.log('✅ 配信履歴読み込み完了:', records.length, '件');
            } catch (error) {
                console.error('❌ 配信履歴読み込みエラー:', error);
                tbody.innerHTML = `
                    <tr>
                        <td colspan="5" style="text-align: center; padding: 40px; color: #ef4444;">
                            エラー: ${error.message}
                        </td>
                    </tr>
                `;
            }
        }

        document.getElementById('refreshHistoryBtn').addEventListener('click', () => {
            const filter = document.getElementById('historyFilter').value;
            loadHistory(filter);
        });

        document.getElementById('historyFilter').addEventListener('change', function() {
            loadHistory(this.value);
        });

        // 初期化
        initializeStatistics();

        // ドメイン保護データの初期読み込み
        loadBlacklistData();
        loadDomainStats();

        // 新機能の初期読み込み
        loadSummaryData();
        loadAlerts();
        loadHistory('all');

            console.log('✅ admin-newsletter-simple 初期化完了');
        }); // DOMContentLoaded終了
    </script>
</BaseLayout>