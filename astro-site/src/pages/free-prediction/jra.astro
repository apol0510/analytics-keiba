---
// Force rebuild: 2026-02-27
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readdirSync, readFileSync, existsSync } from 'fs';
import { join } from 'path';
import { enrichHorse } from '../../lib/horseEnrichment.js';

export const prerender = true;

// 最新の中央競馬予想JSONファイルを取得
const predictionsDir = join(process.cwd(), 'src', 'data', 'predictions', 'jra');
let predictionData = null;
let venues = [];
let isMultiVenue = false;
let error = null;

try {
  if (existsSync(predictionsDir)) {
    // 階層構造（jra/YYYY/MM/YYYY-MM-DD.json）から最新ファイルを検索
    const years = readdirSync(predictionsDir).filter(name => /^\d{4}$/.test(name));
    let latestFile = null;
    let latestPath = null;

    // 全ファイルを収集して日付でソート
    let allFiles = [];

    for (const year of years) {
      const yearPath = join(predictionsDir, year);
      const months = readdirSync(yearPath).filter(name => /^\d{2}$/.test(name));

      for (const month of months) {
        const monthPath = join(yearPath, month);
        const files = readdirSync(monthPath).filter(file => file.endsWith('.json') && /^\d{4}-\d{2}-\d{2}\.json$/.test(file));

        for (const file of files) {
          // ファイル名から日付を抽出（YYYY-MM-DD.json）
          const dateMatch = file.match(/^(\d{4}-\d{2}-\d{2})\.json$/);
          if (dateMatch) {
            allFiles.push({
              date: dateMatch[1],
              path: join(monthPath, file),
              timestamp: new Date(dateMatch[1]).getTime()
            });
          }
        }
      }
    }

    // 日付でソート（最新が先頭）
    allFiles.sort((a, b) => b.timestamp - a.timestamp);

    if (allFiles.length > 0) {
      latestFile = allFiles[0].date + '.json';
      latestPath = allFiles[0].path;
    }

    if (latestPath) {
      const fileContent = readFileSync(latestPath, 'utf-8');
      const rawData = JSON.parse(fileContent);

      // データ構造の判定（venues配列があるか）
      if (rawData.venues && Array.isArray(rawData.venues)) {
        // 複数会場フォーマット
        isMultiVenue = true;
        venues = rawData.venues;
        predictionData = rawData;
      } else if (rawData.eventInfo && rawData.predictions) {
        // 単一会場フォーマット（従来互換）
        isMultiVenue = false;
        venues = [{
          venue: rawData.eventInfo.venue,
          eventInfo: rawData.eventInfo,
          predictions: rawData.predictions
        }];
        predictionData = rawData;
      } else {
        throw new Error('予想データのフォーマットが不正です');
      }
    } else {
      throw new Error('中央競馬の予想データがありません');
    }
  } else {
    throw new Error('中央競馬の予想データフォルダが見つかりません');
  }
} catch (err) {
  error = err.message;
}

// generateAdvancedMetrics imported from featureScores.js
---

<BaseLayout
  title="中央競馬 無料予想 - KEIBA Intelligence"
  description="KEIBA Intelligence 中央競馬（JRA）の無料予想。AI分析による全レース予想（上位5頭）を無料公開。全頭詳細分析と馬単買い目は有料プランで提供。"
>
  <section class="prediction-section">
    <div class="container">
      {error && (
        <div class="error-card">
          <h1>エラー</h1>
          <p>{error}</p>
        </div>
      )}

      {predictionData && (
        <>
          <!-- ページヘッダー（南関版と統一） -->
          <div class="header-section">
            <div class="ai-badge">
              <span class="pulse"></span>
              <span class="ai-status">AI分析完了</span>
            </div>
            <h1 class="race-title">
              {isMultiVenue ? (
                <>{predictionData.date} 中央競馬（JRA） {venues.length}会場</>
              ) : (
                <>{predictionData.eventInfo.date} {predictionData.eventInfo.venue}</>
              )}
            </h1>
          </div>

          <!-- 会場タブ（複数会場の場合のみ表示）-->
          {isMultiVenue && venues.length > 1 && (
            <div class="venue-selector">
              {venues.map((venueData, venueIndex) => (
                <button
                  class={`venue-btn ${venueIndex === 0 ? 'active' : ''}`}
                  data-venue-index={venueIndex}
                  onclick="selectVenue(event, this)"
                >
                  <span class="venue-label">{venueData.venue}</span>
                  <span class="venue-race-count">{venueData.eventInfo.totalRaces}R</span>
                </button>
              ))}
            </div>
          )}

          <!-- 会場ごとの表示エリア -->
          {venues.map((venueData, venueIndex) => {
            const venuePredictions = venueData.predictions;
            const venueInfo = venueData.eventInfo;

            return (
              <div class={`venue-content ${venueIndex === 0 ? 'active' : ''}`} data-venue-index={venueIndex}>
                {/* 会場名（複数会場の場合のみ表示）*/}
                {isMultiVenue && (
                  <div class="venue-header">
                    <h2 class="venue-title">{venueInfo.venue}</h2>
                    <p class="venue-info">{venueInfo.date} - {venueInfo.totalRaces}レース（無料公開）</p>
                  </div>
                )}

                <!-- 全レースアコーディオン（南関版と同じ縦一覧形式） -->
                <div class="jra-race-accordion-list">
                  {venuePredictions.map((race, raceIndex) => {
                    const allHorses = race.horses;
                    // 役割で絞り込み（南関版と統一: 本命・対抗・単穴）
                    const roleHorses = ['本命', '対抗', '単穴']
                      .flatMap(r => allHorses.filter(h => h.role === r));
                    const accordionId = `jra-race-v${venueIndex}-r${raceIndex}`;
                    const distance = race.raceInfo.distance;
                    const distanceLabel = distance
                      ? (typeof distance === 'number' ? `${distance}m` : `${distance}`)
                      : null;

                    return (
                      <div class="jra-race-accordion" data-venue-index={venueIndex}>
                        <button
                          type="button"
                          class="jra-race-accordion-header"
                          data-target={accordionId}
                          aria-expanded="false"
                          aria-controls={accordionId}
                          onclick="toggleJraAccordion(this)"
                        >
                          <div class="jra-race-head-left">
                            <span class="jra-race-num">{race.raceInfo.raceNumber}R</span>
                            <div class="jra-race-meta">
                              {race.raceInfo.raceName && (
                                <span class="jra-race-name">{race.raceInfo.raceName}</span>
                              )}
                              <div class="jra-race-meta-line">
                                {race.raceInfo.startTime && <span class="jra-race-meta-item">🕐 {race.raceInfo.startTime}発走</span>}
                                {distanceLabel && <span class="jra-race-meta-item">📏 {distanceLabel}</span>}
                                {race.raceInfo.horseCount && <span class="jra-race-meta-item">🐴 {race.raceInfo.horseCount}頭</span>}
                              </div>
                            </div>
                          </div>
                          <span class="jra-race-toggle" aria-hidden="true">▼</span>
                        </button>

                        <div class="jra-race-accordion-content" id={accordionId} style="max-height:0;opacity:0">
                          <div class="jra-race-accordion-body">
                        {/* AI選出馬カード（南関版と統一デザイン） */}
                        <div class="analysis-section">
                          <h2 class="section-title">
                            <span>🤖</span>
                            <span>AIモデル選出馬</span>
                          </h2>

                          {roleHorses.map((horse) => {
                            const e = enrichHorse(horse, allHorses, race.raceInfo?.distance);
                            const role = horse.role;
                            const cardClass = role === '本命' ? 'horse-card horse-card-main'
                              : role === '対抗' ? 'horse-card horse-card-sub'
                              : 'horse-card horse-card-tana';
                            const mark = role === '本命' ? '◎' : role === '対抗' ? '○' : '▲';
                            const markClass = role === '本命' ? 'horse-mark-main'
                              : role === '対抗' ? 'horse-mark-sub'
                              : 'horse-mark-tana';
                            const filledStars = (e.stars || '★').length;
                            const ageGenderStr = (e.ageNum != null && e.gender)
                              ? `${e.ageNum}歳${e.gender}`
                              : (horse.age || null);
                            const weightStr = (horse.weight != null && horse.weight !== '' && Number.isFinite(Number(horse.weight)))
                              ? `${horse.weight}kg`
                              : null;
                            const hasBasicInfo = ageGenderStr || weightStr || horse.jockey || horse.trainer || horse.frame != null || horse.computerIndex != null || horse.sire;
                            return (
                              <div class={cardClass}>
                                {role === '本命' && <div class="main-glow" aria-hidden="true"></div>}
                                <div class="horse-header">
                                  <div class="horse-identity">
                                    <span class={markClass}>{mark}</span>
                                    <span class="horse-number">{horse.horseNumber}</span>
                                    <span class="horse-name">{horse.horseName}</span>
                                  </div>
                                  <span class={`role-badge role-badge-${role === '本命' ? 'main' : role === '対抗' ? 'sub' : 'tana'}`}>{role}</span>
                                </div>

                                <div class="horse-stats-row">
                                  <div class="stat-block stat-score-block">
                                    <div class="stat-label">累積スコア</div>
                                    <div class="stat-value stat-score">{e.pt}<span class="stat-unit">pt</span></div>
                                  </div>
                                  <div class="stat-block stat-stars-block">
                                    <div class="stat-label">総合評価</div>
                                    <div class="star-rating" aria-label={`総合評価 ${filledStars}つ星 信頼度${e.confidence}`}>
                                      <span class="star-row">
                                        {[1, 2, 3, 4].map((i) => (
                                          <span class={`star ${i <= filledStars ? 'star-filled' : 'star-empty'}`}>★</span>
                                        ))}
                                      </span>
                                      <span class="confidence-num">（{e.confidence}）</span>
                                    </div>
                                  </div>
                                </div>

                                {hasBasicInfo && (
                                  <div class="basic-info">
                                    <h4>基本情報</h4>
                                    <div class="info-grid">
                                      {(ageGenderStr || weightStr) && (
                                        <div class="info-line info-line-primary">
                                          {ageGenderStr && <span class="info-chip">{ageGenderStr}</span>}
                                          {weightStr && <span class="info-chip">{weightStr}</span>}
                                        </div>
                                      )}
                                      {horse.jockey && (
                                        <div class="info-line"><span class="info-key">騎手</span><span class="info-val">{horse.jockey}</span></div>
                                      )}
                                      {horse.trainer && (
                                        <div class="info-line"><span class="info-key">調教師</span><span class="info-val">{horse.trainer}</span></div>
                                      )}
                                      {horse.frame != null && (
                                        <div class="info-line"><span class="info-key">枠番</span><span class="info-val">{horse.frame}枠</span></div>
                                      )}
                                      {horse.computerIndex != null && (
                                        <div class="info-line"><span class="info-key">指数</span><span class="info-val info-val-strong">{horse.computerIndex}</span></div>
                                      )}
                                      {horse.sire && (
                                        <div class="info-line"><span class="info-key">父</span><span class="info-val">{horse.sire}</span></div>
                                      )}
                                    </div>
                                  </div>
                                )}

                                {e.evalPoints.length > 0 && (
                                  <div class="eval-points">
                                    <h4>評価ポイント</h4>
                                    <div class="eval-tags">
                                      {e.evalPoints.map((p) => (
                                        <span class="eval-tag">{p}</span>
                                      ))}
                                    </div>
                                  </div>
                                )}

                                {e.importance && e.importance.length > 0 && (
                                  <div class="feature-importance">
                                    <h4>特徴量重要度</h4>
                                    <div class="importance-list">
                                      {e.importance.map((item) => (
                                        <div class="importance-item">
                                          <span class="importance-label">{item.label}</span>
                                          <div class="importance-bar">
                                            <div class="importance-fill" style={`width: ${item.value * 100}%`}></div>
                                          </div>
                                          <span class="importance-percent">{Math.round(item.value * 100)}%</span>
                                        </div>
                                      ))}
                                    </div>
                                  </div>
                                )}
                              </div>
                            );
                          })}

                          {/* アクセス制御（南関版と統一） */}
                          <div class="access-control-section">
                            <div class="locked-content">
                              <div class="lock-icon">🔐</div>
                              <h3>連下・押さえ候補馬</h3>
                              <p>より多くの候補馬情報を確認できます</p>
                              <a href="/register" class="unlock-btn unlock-btn-free">無料登録で解放</a>
                            </div>
                            <div class="locked-content">
                              <div class="lock-icon">🔐</div>
                              <h3>AI予測買い目</h3>
                              <p>戦略別の具体的な買い目とAI予測値を提供</p>
                              <a href="/pricing" class="unlock-btn unlock-btn-paid">有料会員で解放</a>
                            </div>
                          </div>
                        </div>
                          </div>
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>
            );
          })}

          <!-- 無料予想について -->
          <div class="free-info-card">
            <div class="free-info-header">
              <div class="info-icon">🎁</div>
              <h2>無料予想について</h2>
            </div>
            <div class="free-info-content">
              <p><strong>無料予想では各レースの本命・対抗・単穴を公開しています。</strong></p>
              <div class="upgrade-benefits">
                <div class="benefit-section">
                  <h3>🆓 無料会員登録でできること</h3>
                  <ul class="free-info-list">
                    <li>✅ 連下・押さえ候補馬の確認</li>
                    <li>✅ 全頭の累積スコア・順位</li>
                    <li>✅ メールマガジン配信</li>
                  </ul>
                  <a href="/register" class="btn btn-success">今すぐ無料登録 →</a>
                </div>
                <div class="benefit-section">
                  <h3>💎 プロ会員でできること</h3>
                  <ul class="free-info-list">
                    <li>✅ 完全な馬単買い目（本線+抑え）</li>
                    <li>✅ 全期間の的中実績</li>
                    <li>✅ 買い目シミュレーター</li>
                    <li>✅ 南関4場＋JRA全10場対応</li>
                    <li>✅ 永久アクセス（買い切りプラン）</li>
                  </ul>
                  <a href="/pricing" class="btn btn-primary">料金プランを見る →</a>
                </div>
              </div>
            </div>
          </div>

          <!-- 過去予想アーカイブリンク -->
          <div class="archive-link-box">
            <a href="/free-prediction-jra/archive">📅 過去の予想アーカイブを見る →</a>
          </div>
        </>
      )}
    </div>
  </section>

  <style>
    /* free-prediction.astroのスタイルを継承 */
    .prediction-section {
      padding: var(--spacing-xl) 0;
      min-height: 100vh;
      background:
        radial-gradient(circle at 20% 20%, rgba(59, 130, 246, 0.1) 0%, transparent 50%),
        radial-gradient(circle at 80% 80%, rgba(139, 92, 246, 0.1) 0%, transparent 50%),
        var(--bg-primary);
    }

    .page-header {
      position: relative;
      text-align: center;
      margin-bottom: var(--spacing-xl);
      padding: var(--spacing-2xl);
      background: linear-gradient(135deg,
        rgba(59, 130, 246, 0.1) 0%,
        rgba(139, 92, 246, 0.1) 100%);
      border-radius: var(--radius-lg);
      border: 1px solid rgba(59, 130, 246, 0.2);
      overflow: hidden;
    }

    .ai-badge {
      display: inline-flex;
      align-items: center;
      gap: var(--spacing-sm);
      padding: var(--spacing-xs) var(--spacing-md);
      background: rgba(59, 130, 246, 0.2);
      border: 1px solid rgba(59, 130, 246, 0.5);
      border-radius: 20px;
      margin-bottom: var(--spacing-md);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 1.5px;
      color: #60a5fa;
    }

    .badge-pulse {
      width: 8px;
      height: 8px;
      background: #3b82f6;
      border-radius: 50%;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(1.2); }
    }

    .free-badge {
      display: inline-flex;
      align-items: center;
      gap: var(--spacing-xs);
      padding: var(--spacing-xs) var(--spacing-md);
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
      border: 1px solid #10b981;
      border-radius: 20px;
      margin-bottom: var(--spacing-md);
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: 1.5px;
      color: white;
      box-shadow: 0 4px 10px rgba(16, 185, 129, 0.3);
    }

    .page-title {
      font-size: 2rem;
      margin-bottom: var(--spacing-sm);
      color: white;
      text-shadow: 0 0 20px rgba(59, 130, 246, 0.5);
      font-weight: 800;
    }

    .page-subtitle {
      font-size: 0.875rem;
      color: rgba(255, 255, 255, 0.7);
      font-family: 'Courier New', monospace;
      letter-spacing: 1.5px;
    }

    .scan-line {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 2px;
      background: linear-gradient(90deg,
        transparent,
        #3b82f6,
        transparent);
      animation: scanLine 2s infinite;
    }

    @keyframes scanLine {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(100%); }
    }

    /* 会場切り替え（角丸セグメント型） */
    .venue-selector {
      display: flex;
      gap: 10px;
      justify-content: center;
      margin: 0 auto 28px;
      padding: 8px;
      background: rgba(15, 23, 42, 0.5);
      border-radius: 999px;
      border: 1px solid rgba(148, 163, 184, 0.2);
      flex-wrap: wrap;
      max-width: max-content;
      backdrop-filter: blur(8px);
    }

    .venue-btn {
      display: inline-flex;
      align-items: baseline;
      gap: 8px;
      padding: 10px 24px;
      background: transparent;
      color: #cbd5e1;
      border: none;
      border-radius: 999px;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .venue-btn:hover {
      background: rgba(139, 92, 246, 0.12);
      color: #e2e8f0;
    }

    .venue-btn.active {
      background: linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%);
      color: white;
      box-shadow: 0 4px 14px rgba(139, 92, 246, 0.45);
    }

    .venue-label {
      font-size: 1.05rem;
      font-weight: 800;
      letter-spacing: 0.02em;
    }

    .venue-race-count {
      font-size: 0.78rem;
      opacity: 0.85;
      font-weight: 700;
    }

    @media (max-width: 768px) {
      .venue-selector {
        max-width: 100%;
        gap: 4px;
        padding: 6px;
      }
      .venue-btn { padding: 8px 16px; }
      .venue-label { font-size: 0.95rem; }
    }

    .venue-content {
      display: none;
    }

    .venue-content.active {
      display: block;
      animation: fadeInUp 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .venue-header {
      text-align: center;
      margin-bottom: var(--spacing-xl);
      padding: var(--spacing-lg);
      background: linear-gradient(135deg,
        rgba(139, 92, 246, 0.15) 0%,
        rgba(167, 139, 250, 0.15) 100%);
      border-radius: var(--radius-lg);
      border: 2px solid rgba(139, 92, 246, 0.3);
    }

    .venue-title {
      font-size: 2rem;
      font-weight: 900;
      color: #a78bfa;
      margin: 0 0 var(--spacing-sm) 0;
      text-shadow: 0 0 15px rgba(167, 139, 250, 0.4);
    }

    .venue-info {
      font-size: 0.875rem;
      color: var(--text-secondary);
      margin: 0;
      font-family: 'Courier New', monospace;
    }

    /* 無料予想説明（角丸・カード型に調整） */
    .free-info-card {
      background: linear-gradient(135deg,
        rgba(251, 191, 36, 0.08) 0%,
        rgba(139, 92, 246, 0.08) 100%);
      padding: 28px;
      border-radius: 18px;
      margin: 36px 0 28px;
      border: 1px solid rgba(251, 191, 36, 0.28);
      box-shadow: 0 8px 28px rgba(0, 0, 0, 0.18);
    }

    .free-info-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 14px;
    }

    .info-icon {
      font-size: 1.5rem;
    }

    .free-info-header h2 {
      font-size: 1.3rem;
      background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      font-weight: 800;
      margin: 0;
    }

    .free-info-content > p {
      color: #cbd5e1;
      margin-bottom: 22px;
      line-height: 1.6;
      font-size: 1.02rem;
    }

    .upgrade-benefits {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
      margin-top: 18px;
    }

    .benefit-section {
      background: rgba(15, 23, 42, 0.55);
      padding: 22px 20px;
      border-radius: 16px;
      border: 1px solid rgba(148, 163, 184, 0.18);
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .benefit-section:first-child {
      border-color: rgba(16, 185, 129, 0.3);
    }
    .benefit-section:last-child {
      border-color: rgba(139, 92, 246, 0.3);
    }

    .benefit-section h3 {
      font-size: 1.05rem;
      font-weight: 800;
      margin: 0;
      color: #e2e8f0;
    }

    .free-info-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .free-info-list li {
      padding: 2px 0;
      color: #cbd5e1;
      line-height: 1.6;
      font-size: 0.92rem;
    }

    .benefit-section .btn {
      width: 100%;
      justify-content: center;
      font-weight: 700;
      padding: 12px 20px;
      border-radius: 999px;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 0.95rem;
      transition: all 0.25s ease;
      margin-top: auto;
    }
    .benefit-section .btn-success {
      background: linear-gradient(135deg, #10b981, #22c55e);
      color: white;
      border: none;
    }
    .benefit-section .btn-success:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 18px rgba(16, 185, 129, 0.4);
    }
    .benefit-section .btn-primary {
      background: linear-gradient(135deg, #8b5cf6, #ec4899);
      color: white;
      border: none;
    }
    .benefit-section .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 18px rgba(139, 92, 246, 0.4);
    }

    @media (max-width: 768px) {
      .upgrade-benefits {
        grid-template-columns: 1fr;
        gap: 14px;
      }
      .free-info-card { padding: 22px 18px; margin: 28px 0 24px; }
    }

    /* 過去予想アーカイブリンク（角丸ピル） */
    .archive-link-box {
      text-align: center;
      margin: 24px 0 12px;
    }
    .archive-link-box a {
      display: inline-block;
      padding: 12px 24px;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.6);
      border: 1px solid rgba(148, 163, 184, 0.2);
      color: #cbd5e1;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.95rem;
      transition: all 0.25s ease;
    }
    .archive-link-box a:hover {
      background: rgba(59, 130, 246, 0.12);
      border-color: rgba(59, 130, 246, 0.4);
      color: #e2e8f0;
      text-decoration: none;
    }

    /* レース選択ボタン */
    .race-selector {
      display: flex;
      flex-wrap: wrap;
      gap: var(--spacing-sm);
      justify-content: center;
      margin-bottom: var(--spacing-xl);
      padding: var(--spacing-lg);
      background: var(--bg-secondary);
      border-radius: var(--radius-lg);
      border: 1px solid var(--border-color);
    }

    .race-btn {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      padding: var(--spacing-sm) var(--spacing-md);
      background: var(--bg-tertiary);
      color: var(--text-primary);
      border: 2px solid var(--border-color);
      border-radius: var(--radius-md);
      font-size: 0.875rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .race-btn:hover {
      border-color: var(--primary-end);
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
    }

    .race-btn.active {
      background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
      border-color: var(--primary-end);
      color: white;
      box-shadow: 0 4px 16px rgba(59, 130, 246, 0.4);
    }

    .race-label {
      font-size: 1rem;
      font-weight: 800;
    }

    .race-indicator {
      width: 20px;
      height: 2px;
      background: var(--border-color);
      border-radius: 1px;
      transition: all 0.3s;
    }

    .race-btn.active .race-indicator {
      background: white;
      box-shadow: 0 0 8px rgba(255, 255, 255, 0.8);
    }

    /* レース表示 */
    .race-display-area {
      position: relative;
      min-height: 500px;
    }

    .race-content {
      display: none;
    }

    .race-content.active {
      display: block;
      animation: fadeInUp 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .race-name-header {
      text-align: center;
      margin-bottom: var(--spacing-xl);
      padding: var(--spacing-lg);
      background: linear-gradient(135deg,
        rgba(139, 92, 246, 0.15) 0%,
        rgba(59, 130, 246, 0.15) 100%);
      border-radius: var(--radius-lg);
      border: 2px solid rgba(139, 92, 246, 0.3);
    }

    .race-name-title {
      font-size: 1.5rem;
      font-weight: 800;
      color: #a78bfa;
      margin: 0 0 var(--spacing-md) 0;
      text-shadow: 0 0 10px rgba(167, 139, 250, 0.3);
      letter-spacing: 0.5px;
    }

    .race-details {
      display: flex;
      justify-content: center;
      gap: var(--spacing-lg);
      flex-wrap: wrap;
      margin-top: var(--spacing-md);
    }

    .race-detail-item {
      font-size: 0.95rem;
      color: #94a3b8;
      font-weight: 600;
      padding: var(--spacing-xs) var(--spacing-md);
      background: rgba(30, 41, 59, 0.5);
      border-radius: var(--radius-md);
      border: 1px solid rgba(139, 92, 246, 0.2);
    }

    .analysis-section {
      background: var(--bg-secondary);
      padding: var(--spacing-xl);
      border-radius: var(--radius-lg);
      margin-bottom: var(--spacing-xl);
    }

    .section-header {
      display: flex;
      align-items: center;
      gap: var(--spacing-sm);
      margin-bottom: var(--spacing-lg);
    }

    .header-icon {
      font-size: 1.5rem;
      filter: drop-shadow(0 0 8px rgba(59, 130, 246, 0.5));
    }

    .section-header h2 {
      font-size: 1.25rem;
      color: #60a5fa;
      font-weight: 800;
    }

    .detailed-horse-card {
      position: relative;
      margin-bottom: var(--spacing-lg);
      padding: var(--spacing-lg);
      background: var(--bg-tertiary);
      border-radius: var(--radius-md);
      border: 2px solid var(--border-color);
    }

    .detailed-horse-card.top-horse-detailed,
    .detailed-horse-card.top-horse-simple {
      margin-bottom: var(--spacing-lg);
      position: relative;
    }

    .detailed-horse-card.top-horse-detailed {
      border-color: rgba(251, 191, 36, 0.5);
      background: linear-gradient(135deg,
        rgba(251, 191, 36, 0.05) 0%,
        rgba(30, 41, 59, 0.8) 100%);
    }

    .detailed-horse-card.top-horse-detailed .dhc-header,
    .detailed-horse-card.top-horse-simple .dhc-header {
      padding-top: calc(var(--spacing-md) + 40px);
    }

    .detailed-horse-card.top-horse-simple {
      background: var(--bg-card);
      border: 1px solid rgba(251, 191, 36, 0.2);
    }

    .detailed-horse-card.top-horse-simple:hover {
      border-color: rgba(251, 191, 36, 0.4);
    }

    .dhc-header {
      margin-bottom: var(--spacing-xl);
    }

    .dhc-main-info {
      width: 100%;
    }

    .rank-badge-large {
      position: absolute;
      top: var(--spacing-md);
      left: var(--spacing-md);
      background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
      color: #1e293b;
      font-weight: 700;
      font-size: 1.125rem;
      padding: var(--spacing-xs) var(--spacing-md);
      border-radius: var(--radius-md);
      box-shadow: 0 2px 8px rgba(251, 191, 36, 0.3);
      z-index: 1;
    }

    .candidate-badge {
      position: absolute;
      top: var(--spacing-md);
      left: var(--spacing-md);
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.3) 0%, rgba(167, 139, 250, 0.3) 100%);
      color: #a78bfa;
      font-weight: 600;
      font-size: 0.95rem;
      padding: var(--spacing-xs) var(--spacing-md);
      border-radius: var(--radius-md);
      border: 1px solid rgba(139, 92, 246, 0.5);
      z-index: 1;
    }

    .dhc-info-card {
      background: rgba(30, 41, 59, 0.5);
      padding: var(--spacing-md);
      border-radius: var(--radius-sm);
    }

    .dhc-title-line {
      display: flex;
      align-items: center;
      gap: var(--spacing-sm);
      margin-bottom: var(--spacing-md);
      flex-wrap: wrap;
    }

    .dhc-mark-mobile {
      font-size: 1.5rem;
      font-weight: 900;
    }

    .detailed-horse-card.honmei .dhc-mark-mobile {
      color: #3b82f6;
    }

    .detailed-horse-card.taikou .dhc-mark-mobile {
      color: #8b5cf6;
    }

    .detailed-horse-card.tanana .dhc-mark-mobile {
      color: #f59e0b;
    }

    .dhc-number {
      font-size: 1.25rem;
      font-weight: 900;
      color: #60a5fa;
      font-family: 'Courier New', monospace;
      padding: 4px 12px;
      background: rgba(96, 165, 250, 0.15);
      border: 2px solid rgba(96, 165, 250, 0.4);
      border-radius: var(--radius-sm);
    }

    .dhc-name {
      font-size: 1.125rem;
      font-weight: 700;
      color: var(--text-primary);
      flex: 1;
    }

    .dhc-role-badge {
      padding: 4px 12px;
      background: rgba(139, 92, 246, 0.2);
      border: 1px solid rgba(139, 92, 246, 0.5);
      border-radius: 12px;
      font-size: 0.75rem;
      font-weight: 600;
      color: #a78bfa;
    }

    .dhc-pt {
      padding: 4px 12px;
      background: rgba(16, 185, 129, 0.2);
      border: 1px solid rgba(16, 185, 129, 0.5);
      border-radius: 12px;
      font-size: 0.75rem;
      font-weight: 700;
      color: #10b981;
      font-family: 'Courier New', monospace;
    }

    .dhc-jockey-trainer {
      display: flex;
      gap: var(--spacing-md);
      margin-top: var(--spacing-sm);
      font-size: 0.9rem;
      color: #94a3b8;
      flex-wrap: wrap;
    }

    .dhc-age, .dhc-weight, .dhc-jockey, .dhc-trainer {
      padding: var(--spacing-xs) var(--spacing-sm);
      background: rgba(30, 41, 59, 0.5);
      border-radius: var(--radius-sm);
      border: 1px solid rgba(59, 130, 246, 0.2);
    }

    .dhc-quick-metrics {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--spacing-sm);
    }

    .qm-item {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .qm-label {
      font-size: 0.65rem;
      color: var(--text-tertiary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .qm-value {
      font-size: 1rem;
      font-weight: 800;
      color: var(--text-primary);
      font-family: 'Courier New', monospace;
    }

    .qm-value.risk-low { color: #10b981; }
    .qm-value.risk-medium { color: #f59e0b; }
    .qm-value.risk-high { color: #ef4444; }
    .qm-value.positive { color: #10b981; }
    .qm-value.negative { color: #ef4444; }

    /* 特徴量分析 */
    .dhc-features {
      margin-bottom: var(--spacing-xl);
    }

    .feature-title {
      font-size: 1rem;
      font-weight: 700;
      color: #60a5fa;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: var(--spacing-md);
      padding-bottom: var(--spacing-sm);
      border-bottom: 2px solid rgba(96, 165, 250, 0.3);
    }

    .feature-grid {
      display: grid;
      gap: var(--spacing-md);
    }

    .feature-item {
      display: grid;
      grid-template-columns: 200px 1fr 60px;
      align-items: center;
      gap: var(--spacing-sm);
      padding: var(--spacing-sm);
      background: rgba(30, 41, 59, 0.3);
      border-radius: var(--radius-sm);
    }

    .feature-label {
      display: flex;
      align-items: center;
      gap: var(--spacing-xs);
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .feature-icon {
      font-size: 1.25rem;
    }

    .feature-bar-container {
      position: relative;
      height: 8px;
      background: rgba(0, 0, 0, 0.4);
      border-radius: 4px;
      overflow: hidden;
    }

    .feature-bar {
      height: 100%;
      background: linear-gradient(90deg, #3b82f6, #8b5cf6);
      border-radius: 4px;
      transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      overflow: hidden;
    }

    .feature-bar::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(90deg,
        transparent 0%,
        rgba(255, 255, 255, 0.2) 50%,
        transparent 100%);
      animation: shimmer 2s infinite;
    }

    @keyframes shimmer {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(100%); }
    }

    .feature-bar-container.trend {
      position: relative;
      background: linear-gradient(90deg,
        rgba(239, 68, 68, 0.3) 0%,
        rgba(100, 100, 100, 0.3) 50%,
        rgba(16, 185, 129, 0.3) 100%);
    }

    .feature-bar-center {
      position: absolute;
      left: 50%;
      top: 0;
      width: 2px;
      height: 100%;
      background: rgba(255, 255, 255, 0.5);
      transform: translateX(-50%);
    }

    .feature-bar.trend {
      position: absolute;
      top: 0;
      height: 100%;
      background: linear-gradient(90deg, rgba(16, 185, 129, 0.8), rgba(16, 185, 129, 1));
    }

    .feature-value {
      text-align: right;
      font-weight: 700;
      font-family: 'Courier New', monospace;
      color: #60a5fa;
      font-size: 0.9rem;
    }

    /* アップグレードCTAボックス */
    .upgrade-cta-box {
      background: linear-gradient(135deg, rgba(251, 191, 36, 0.1) 0%, rgba(245, 158, 11, 0.1) 100%);
      border: 2px solid #fbbf24;
      border-radius: var(--radius-lg);
      padding: var(--spacing-xl);
      text-align: center;
      margin: var(--spacing-xl) 0;
      box-shadow: 0 0 20px rgba(251, 191, 36, 0.2);
    }

    .upgrade-icon {
      font-size: 3rem;
      margin-bottom: var(--spacing-md);
      filter: drop-shadow(0 0 10px rgba(251, 191, 36, 0.5));
    }

    .upgrade-cta-box h3 {
      font-size: 1.5rem;
      background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: var(--spacing-md);
      font-weight: 800;
    }

    .upgrade-cta-box p {
      color: var(--text-secondary);
      margin-bottom: var(--spacing-lg);
      line-height: 1.6;
      font-size: 1.05rem;
    }

    .upgrade-benefits-mini {
      display: flex;
      gap: var(--spacing-md);
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: var(--spacing-lg);
    }

    .upgrade-benefits-mini span {
      padding: var(--spacing-xs) var(--spacing-md);
      background: rgba(251, 191, 36, 0.15);
      border: 1px solid rgba(251, 191, 36, 0.3);
      border-radius: var(--radius-md);
      font-size: 0.9rem;
      font-weight: 600;
      color: #fbbf24;
    }

    /* 買い目ロック（ブラープレビュー版） */
    .locked-section {
      position: relative;
      background: linear-gradient(135deg,
        rgba(245, 158, 11, 0.05) 0%,
        rgba(251, 191, 36, 0.05) 100%);
      padding: var(--spacing-lg) var(--spacing-xl);
      border-radius: var(--radius-lg);
      min-height: 300px;
      border: 2px solid rgba(245, 158, 11, 0.3);
      box-shadow:
        0 4px 6px rgba(0, 0, 0, 0.1),
        inset 0 1px 0 rgba(255, 255, 255, 0.05);
      overflow: hidden;
      margin-bottom: var(--spacing-xl);
    }

    /* ブラーされたコンテンツ */
    .blurred-preview .blurred-content {
      filter: blur(8px);
      opacity: 0.6;
      user-select: none;
      pointer-events: none;
    }

    .betting-preview-card {
      background: rgba(30, 41, 59, 0.6);
      border: 1px solid rgba(100, 116, 139, 0.3);
      border-radius: var(--radius-md);
      padding: var(--spacing-lg);
    }

    .betting-preview-card h4 {
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: var(--spacing-md);
      color: var(--text-primary);
    }

    .betting-formula-preview {
      margin-bottom: var(--spacing-lg);
    }

    .betting-formula-preview .main-line,
    .betting-formula-preview .backup-line {
      display: flex;
      align-items: center;
      gap: var(--spacing-md);
      padding: var(--spacing-md);
      background: rgba(59, 130, 246, 0.1);
      border-radius: var(--radius-sm);
      margin-bottom: var(--spacing-sm);
    }

    .betting-formula-preview .label {
      font-weight: 700;
      color: var(--color-accent);
      min-width: 60px;
    }

    .betting-formula-preview .formula {
      font-family: 'Courier New', monospace;
      font-size: 1.125rem;
      color: var(--text-primary);
      font-weight: 700;
    }

    .betting-info-preview {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-md);
    }

    .betting-info-preview .info-item {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-xs);
    }

    .betting-info-preview .label {
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .betting-info-preview .value {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--color-accent);
    }

    .lock-overlay {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: rgba(15, 23, 42, 0.85);
      backdrop-filter: blur(10px) saturate(180%);
      -webkit-backdrop-filter: blur(10px) saturate(180%);
      text-align: center;
      padding: var(--spacing-xl);
      max-width: 600px;
      margin: 0 auto;
      padding: var(--spacing-lg);
    }

    .lock-icon {
      font-size: 2.5rem;
      margin-bottom: var(--spacing-md);
      opacity: 0.7;
      filter: drop-shadow(0 0 10px rgba(245, 158, 11, 0.3));
    }

    .lock-overlay h3 {
      font-size: 1.25rem;
      font-weight: 800;
      color: #fbbf24;
      margin-bottom: var(--spacing-sm);
      text-shadow: 0 0 10px rgba(251, 191, 36, 0.3);
    }

    .lock-overlay p {
      color: var(--text-secondary);
      margin-bottom: var(--spacing-lg);
      line-height: 1.5;
      font-size: 0.9375rem;
    }

    .lock-buttons {
      display: flex;
      gap: var(--spacing-md);
      justify-content: center;
      flex-wrap: wrap;
      z-index: 10;
      position: relative;
    }

    .lock-buttons .btn {
      min-width: 160px;
    }

    /* CTA */
    .error-card {
      text-align: center;
      padding: var(--spacing-2xl);
      background: var(--bg-secondary);
      border-radius: var(--radius-lg);
      border: 1px solid rgba(239, 68, 68, 0.5);
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* レスポンシブ */
    @media (max-width: 1024px) {
      .feature-item {
        grid-template-columns: 150px 1fr 50px;
      }

      .upgrade-benefits {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 768px) {
      .page-title {
        font-size: 1.5rem;
      }

      .dhc-quick-metrics {
        grid-template-columns: repeat(2, 1fr);
      }

      .cta-buttons {
        flex-direction: column;
      }

      .feature-item {
        grid-template-columns: 1fr;
        gap: var(--spacing-sm);
      }

      .feature-label {
        justify-content: space-between;
      }

      .upgrade-benefits {
        grid-template-columns: 1fr;
      }

      .upgrade-benefits-mini {
        gap: var(--spacing-sm);
      }

      .upgrade-benefits-mini span {
        font-size: 0.8rem;
        padding: 4px var(--spacing-sm);
      }

      .rank-badge-large {
        font-size: 0.9rem;
        padding: 4px var(--spacing-sm);
      }
    }

    /* ======================================================
       JRA レースアコーディオン（南関版相当の縦一覧）
       ====================================================== */
    .jra-race-accordion-list {
      display: grid;
      gap: 10px;
      margin-top: 8px;
    }
    .jra-race-accordion {
      background: rgba(16, 185, 129, 0.05);
      border-radius: 14px;
      border: 1px solid rgba(16, 185, 129, 0.22);
      overflow: hidden;
      transition: border-color 0.25s ease, transform 0.25s ease;
    }
    .jra-race-accordion:hover {
      border-color: rgba(16, 185, 129, 0.4);
    }
    .jra-race-accordion-header {
      width: 100%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 14px;
      padding: 14px 18px;
      background: linear-gradient(135deg, rgba(16, 185, 129, 0.10) 0%, rgba(16, 185, 129, 0.04) 100%);
      border: none;
      cursor: pointer;
      text-align: left;
      color: inherit;
      font: inherit;
      transition: background 0.25s ease;
    }
    .jra-race-accordion-header:hover {
      background: linear-gradient(135deg, rgba(16, 185, 129, 0.18) 0%, rgba(16, 185, 129, 0.08) 100%);
    }
    .jra-race-accordion-header[aria-expanded="true"] {
      background: linear-gradient(135deg, rgba(16, 185, 129, 0.22) 0%, rgba(59, 130, 246, 0.10) 100%);
      border-bottom: 1px solid rgba(16, 185, 129, 0.25);
    }
    .jra-race-head-left {
      display: flex;
      align-items: center;
      gap: 14px;
      min-width: 0;
      flex: 1;
    }
    .jra-race-num {
      flex-shrink: 0;
      background: linear-gradient(135deg, #8b5cf6, #7c3aed);
      color: white;
      padding: 8px 14px;
      border-radius: 10px;
      font-weight: 800;
      font-size: 1.05rem;
      letter-spacing: 0.02em;
      box-shadow: 0 2px 8px rgba(139, 92, 246, 0.35);
    }
