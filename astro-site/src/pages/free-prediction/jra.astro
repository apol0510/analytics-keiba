  <script is:inline>
    function selectVenue(event, button) {
      event.preventDefault();

      const venueIndex = button.getAttribute('data-venue-index');

      // 会場タブの切り替え
      document.querySelectorAll('.venue-btn').forEach(btn => {
        btn.classList.remove('active');
      });
      button.classList.add('active');

      // 会場コンテンツの切り替え
      document.querySelectorAll('.venue-content').forEach(content => {
        content.classList.remove('active');
      });

      const selectedVenue = document.querySelector(`.venue-content[data-venue-index="${venueIndex}"]`);
      if (selectedVenue) {
        selectedVenue.classList.add('active');
      }

      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // アコーディオン: 同じ会場内で他を閉じてからトグル
    function toggleJraAccordion(headerEl) {
      const targetId = headerEl.getAttribute('data-target');
      const target = document.getElementById(targetId);
      if (!target) return;

      const venue = headerEl.closest('.venue-content');
      const isOpen = headerEl.getAttribute('aria-expanded') === 'true';

      // 同会場内の他アコーディオンを閉じる
      if (venue) {
        venue.querySelectorAll('.jra-race-accordion-header').forEach(h => {
          if (h !== headerEl) {
            const tid = h.getAttribute('data-target');
            const t = tid ? document.getElementById(tid) : null;
            if (t) {
              t.style.maxHeight = '0px';
              t.style.opacity = '0';
            }
            h.setAttribute('aria-expanded', 'false');
            const ic = h.querySelector('.jra-race-toggle');
            if (ic) {
              ic.textContent = '▼';
              ic.style.transform = 'rotate(0deg)';
            }
          }
        });
      }

      // 自身をトグル
      const icon = headerEl.querySelector('.jra-race-toggle');
      if (isOpen) {
        target.style.maxHeight = '0px';
        target.style.opacity = '0';
        headerEl.setAttribute('aria-expanded', 'false');
        if (icon) {
          icon.textContent = '▼';
          icon.style.transform = 'rotate(0deg)';
        }
      } else {
        target.style.maxHeight = target.scrollHeight + 'px';
        target.style.opacity = '1';
        headerEl.setAttribute('aria-expanded', 'true');
        if (icon) {
          icon.textContent = '◎';
          icon.style.transform = 'rotate(180deg)';
        }
      }
    }
    window.toggleJraAccordion = toggleJraAccordion;
  </script>
