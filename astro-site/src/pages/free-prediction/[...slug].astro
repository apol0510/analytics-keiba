/* レスポンシブ */
@media (max-width: 768px) {
    .archive-banner {
        flex-direction: column;
        text-align: center;
    }

    .main-title {
        font-size: 24px;
    }

    .stats-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .strategies-grid {
        grid-template-columns: 1fr;
    }

    .cta-buttons {
        flex-direction: column;
    }

    .btn {
        width: 100%;
    }
}
</style>
