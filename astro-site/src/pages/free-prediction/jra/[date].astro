    }

    .rr-distance {
      color: var(--text-secondary);
    }

    .rr-condition {
      color: var(--text-secondary);
      font-size: 0.75rem;
    }

    /* ナビゲーション */
    .archive-nav {
      display: flex;
      gap: var(--spacing-lg);
      justify-content: center;
      margin-top: var(--spacing-2xl);
      padding: var(--spacing-xl);
      background: var(--bg-secondary);
      border-radius: var(--radius-lg);
      border: 1px solid var(--border-color);
      flex-wrap: wrap;
    }

    .nav-link {
      display: flex;
      align-items: center;
      gap: var(--spacing-sm);
      padding: var(--spacing-md) var(--spacing-xl);
      background: var(--bg-tertiary);
      color: var(--text-primary);
      text-decoration: none;
      border: 2px solid var(--border-color);
      border-radius: var(--radius-md);
      font-weight: 700;
      font-size: 0.95rem;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .nav-link:hover {
      border-color: #3b82f6;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
      color: #60a5fa;
    }

    .nav-icon {
      font-size: 1.2rem;
    }

    /* レスポンシブ */
    @media (max-width: 768px) {
      .page-title {
        font-size: 1.25rem;
      }

      .dhc-header {
        flex-direction: column;
        align-items: stretch;
      }

      .rank-badge-large {
        align-self: flex-start;
        min-width: auto;
        height: auto;
        padding: 4px var(--spacing-sm);
        font-size: 0.9rem;
      }

      .dhc-quick-metrics {
        grid-template-columns: repeat(2, 1fr);
      }

      .feature-item {
        grid-template-columns: 1fr;
        gap: 4px;
      }

      .feature-label {
        justify-content: space-between;
      }

      .feature-value {
        text-align: left;
      }

      .archive-nav {
        flex-direction: column;
        align-items: stretch;
      }

      .nav-link {
        justify-content: center;
      }

      .venue-selector {
        gap: var(--spacing-sm);
      }

      .venue-btn {
        min-width: 90px;
        padding: var(--spacing-sm) var(--spacing-md);
      }

      .venue-label {
        font-size: 1rem;
      }

      .section-header h2 {
        font-size: 0.9rem;
      }

      .recent-races-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script is:inline>
    function selectVenue(event, button) {
      event.preventDefault();

      const venueIndex = button.getAttribute('data-venue-index');

      // 会場タブの切り替え
      document.querySelectorAll('.venue-btn').forEach(btn => {
        btn.classList.remove('active');
      });
      button.classList.add('active');

      // 会場コンテンツの切り替え
      document.querySelectorAll('.venue-content').forEach(content => {
        content.classList.remove('active');
      });

      const selectedVenue = document.querySelector(`.venue-content[data-venue-index="${venueIndex}"]`);
      if (selectedVenue) {
        selectedVenue.classList.add('active');
      }

      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function selectRace(event, button) {
      event.preventDefault();

      const venueIndex = button.getAttribute('data-venue-index');
      const raceIndex = button.getAttribute('data-race-index');

      // 現在の会場内のレースボタンのみ更新
      const currentVenue = document.querySelector(`.venue-content[data-venue-index="${venueIndex}"]`);
      if (!currentVenue) return;

      currentVenue.querySelectorAll('.race-btn').forEach(btn => {
        btn.classList.remove('active');
      });
      button.classList.add('active');

      // 現在の会場内のレースコンテンツのみ更新
      currentVenue.querySelectorAll('.race-content').forEach(content => {
        content.classList.remove('active');
      });

      const selectedRace = currentVenue.querySelector(`.race-content[data-venue-index="${venueIndex}"][data-race-index="${raceIndex}"]`);
      if (selectedRace) {
        selectedRace.classList.add('active');
      }
    }
  </script>
</BaseLayout>
