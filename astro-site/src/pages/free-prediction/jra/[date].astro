      font-weight: 900;
    }

    .dhc-name {
      font-size: 1.25rem;
      font-weight: 800;
      color: var(--text-primary);
    }

    .dhc-role {
      font-size: 0.75rem;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 4px;
      color: white;
    }

    .role-本命 { background: #ef4444; }
    .role-対抗 { background: #f97316; }
    .role-単穴 { background: #eab308; }
    .role-連下 { background: #22c55e; }
    .role-穴 { background: #8b5cf6; }

    .dhc-jockey-trainer {
      display: flex;
      gap: var(--spacing-md);
      flex-wrap: wrap;
      font-size: 0.85rem;
      color: var(--text-secondary);
    }

    .dhc-quick-metrics {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--spacing-sm);
      margin-top: var(--spacing-sm);
    }

    .qm-item {
      display: flex;
      flex-direction: column;
      gap: 2px;
      padding: var(--spacing-xs) var(--spacing-sm);
      background: rgba(30, 41, 59, 0.5);
      border-radius: var(--radius-sm);
      border: 1px solid var(--border-color);
