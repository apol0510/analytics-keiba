    }

    .qm-value {
      font-size: 1rem;
      font-weight: 800;
      color: #60a5fa;
      font-family: 'Courier New', monospace;
    }

    .qm-value.positive { color: #10b981; }
    .qm-value.negative { color: #ef4444; }

    /* Feature Importance */
    .dhc-features {
      margin-top: var(--spacing-lg);
      padding-top: var(--spacing-lg);
      border-top: 1px solid var(--border-color);
    }

    .feature-title {
      font-size: 0.85rem;
      font-weight: 700;
      color: #60a5fa;
      margin-bottom: var(--spacing-md);
      letter-spacing: 0.5px;
    }

    .feature-grid {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-sm);
    }

    .feature-item {
      display: grid;
      grid-template-columns: 200px 1fr 50px;
      align-items: center;
      gap: var(--spacing-sm);
    }

    .feature-label {
      display: flex;
      align-items: center;
      gap: var(--spacing-xs);
