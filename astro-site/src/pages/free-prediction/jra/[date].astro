      border-radius: var(--radius-md);
      color: white;
      font-size: 1rem;
      font-weight: 900;
      white-space: nowrap;
      box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
    }

    .dhc-main-info {
      flex: 1;
    }

    .dhc-info-card {
