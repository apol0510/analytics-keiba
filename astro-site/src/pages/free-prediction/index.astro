---
import { readdirSync, readFileSync, existsSync, statSync } from 'fs';
import { join } from 'path';

export const prerender = false;

// 南関の最新予想日付（src/data/predictions/*.json から拾う）
function readLatestNankanDate(): string | null {
  const dir = join(process.cwd(), 'src', 'data', 'predictions');
  if (!existsSync(dir)) return null;
  try {
    const files = readdirSync(dir)
      .filter((name) => /^\d{4}-\d{2}-\d{2}/.test(name) && name.endsWith('.json'))
      .sort()
      .reverse();
    if (files.length === 0) return null;
    const m = files[0].match(/^(\d{4}-\d{2}-\d{2})/);
    return m ? m[1] : null;
  } catch {
    return null;
  }
}

// JRAの最新予想日付（src/data/predictions/jra/YYYY/MM/YYYY-MM-DD.json から拾う）
function readLatestJraDate(): string | null {
  const root = join(process.cwd(), 'src', 'data', 'predictions', 'jra');
  if (!existsSync(root)) return null;
  try {
    const years = readdirSync(root).filter((n) => /^\d{4}$/.test(n)).sort().reverse();
    for (const y of years) {
      const yearDir = join(root, y);
      if (!statSync(yearDir).isDirectory()) continue;
      const months = readdirSync(yearDir).filter((n) => /^\d{2}$/.test(n)).sort().reverse();
      for (const m of months) {
        const monthDir = join(yearDir, m);
        if (!statSync(monthDir).isDirectory()) continue;
        const files = readdirSync(monthDir)
          .filter((n) => /^\d{4}-\d{2}-\d{2}/.test(n) && n.endsWith('.json'))
          .sort()
          .reverse();
        if (files.length > 0) {
          const match = files[0].match(/^(\d{4}-\d{2}-\d{2})/);
          if (match) return match[1];
        }
      }
    }
    return null;
  } catch {
    return null;
  }
}

const nankanLatest = readLatestNankanDate();
const jraLatest = readLatestJraDate();

const formatDate = (date: string | null): string => {
  if (!date) return '';
  const [, m, d] = date.split('-');
  return `${parseInt(m, 10)}月${parseInt(d, 10)}日`;
};
