---
// 互換リダイレクトページ（旧URL → 新URL）
// netlify.toml の 301 が何らかの理由で効かないケースを保険として受ける。
// meta refresh + JS replace + canonical(new) + noindex で SEO もカバー。
export const prerender = true;
const target = '/free-prediction/nankan/';
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>移動しました — /free-prediction/nankan/</title>
  <meta http-equiv="refresh" content={`0; url=${target}`}>
  <link rel="canonical" href={target}>
  <meta name="robots" content="noindex,follow">
  <script is:inline define:vars={{ target }}>
    window.location.replace(target);
  </script>
</head>
<body>
  <p>このページは <a href={target}>{target}</a> に移動しました。</p>
</body>
</html>
