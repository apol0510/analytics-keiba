    <script is:inline>
      // 画像自動設定（クライアントサイドで今日の日付計算）
      (function() {
        const img = document.getElementById('hitImage');
        const now = new Date();
        const jst = new Date(now.toLocaleString('en-US', { timeZone: 'Asia/Tokyo' }));
        // jst.setDate(jst.getDate() - 1); // 昨日 → 今日に変更

        function tryLoadImage(daysBack) {
          const testDate = new Date(jst);
          testDate.setDate(testDate.getDate() - daysBack);
          const year = testDate.getFullYear();
          const month = String(testDate.getMonth() + 1).padStart(2, '0');
          const day = String(testDate.getDate()).padStart(2, '0');
          const dateStr = `${year}${month}${day}`;
          const imagePath = `/upsell-images/upsell-${dateStr}.png`;

          img.src = imagePath;
          console.log(`[withdrawal-upsell] 画像読み込み試行: ${imagePath}`);

          if (daysBack < 10) {
            img.onerror = function() {
              console.log(`[withdrawal-upsell] 画像なし、${daysBack + 1}日前を試行`);
              tryLoadImage(daysBack + 1);
            };
          } else {
            img.onerror = function() {
              console.error('[withdrawal-upsell] 10日前まで画像が見つかりませんでした');
            };
          }
        }

        tryLoadImage(0);
      })();

      // 退会モーダル制御（DOMContentLoaded内で実行）
      document.addEventListener('DOMContentLoaded', function() {
        const modal = document.getElementById('withdrawalModal');
        const proceedBtn = document.getElementById('proceedWithdrawal');
        const confirmBtn = document.getElementById('confirmWithdrawal');
        const cancelBtn = document.getElementById('cancelWithdrawal');
        const reasonTextarea = document.getElementById('withdrawalReason');

        if (!proceedBtn || !confirmBtn || !cancelBtn) {
          console.error('[withdrawal-upsell] 退会ボタンが見つかりません');
          return;
        }

        proceedBtn.addEventListener('click', function() {
          console.log('[withdrawal-upsell] 退会手続きボタンがクリックされました');
          // ページトップにスクロール
          window.scrollTo(0, 0);
          modal.style.display = 'block';
        });

        cancelBtn.addEventListener('click', function() {
          modal.style.display = 'none';
        });

        confirmBtn.addEventListener('click', async function() {
        const reason = reasonTextarea.value || '理由未記入';
        const email = localStorage.getItem('userEmail') || '';

        if (!email) {
          alert('メールアドレスが取得できませんでした。ダッシュボードから再度お試しください。');
          return;
        }

        // ボタンを無効化
        confirmBtn.disabled = true;
        confirmBtn.textContent = '処理中...';

        try {
          // 退会処理APIを呼び出し
          const response = await fetch('/.netlify/functions/process-withdrawal', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              email: email,
              reason: reason
            })
          });

          const result = await response.json();

          if (response.ok) {
            // 成功時: 完了ページにリダイレクト
            alert('退会申請を受け付けました。確認メールをお送りしましたのでご確認ください。');
            window.location.href = '/';
          } else {
            throw new Error(result.error || '退会申請の送信に失敗しました');
          }
        } catch (error) {
          alert(`エラーが発生しました: ${error.message}\n\nお手数ですが、お問い合わせフォームからご連絡ください。`);
          confirmBtn.disabled = false;
          confirmBtn.textContent = '退会する';
        }
        });

        // モーダル外クリックで閉じる
        modal.addEventListener('click', function(e) {
          if (e.target === modal) {
            modal.style.display = 'none';
          }
        });
      }); // DOMContentLoaded の閉じカッコ
    </script>

  </div>

    <!-- 銀行振込モーダル -->
