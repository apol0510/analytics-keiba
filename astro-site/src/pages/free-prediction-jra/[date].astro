---
import { readdirSync, existsSync } from 'fs';
import { join } from 'path';

export const prerender = true;

// 新URL側 (/free-prediction/jra/[date]/) と同じ日付集合を事前生成
export function getStaticPaths() {
  const predictionsDir = join(process.cwd(), 'src', 'data', 'predictions', 'jra');
  const paths = [];
  if (!existsSync(predictionsDir)) return paths;
  const years = readdirSync(predictionsDir).filter(n => /^\d{4}$/.test(n));
  for (const year of years) {
    const yearPath = join(predictionsDir, year);
    if (!existsSync(yearPath)) continue;
    const months = readdirSync(yearPath).filter(n => /^\d{2}$/.test(n));
    for (const month of months) {
      const monthPath = join(yearPath, month);
      if (!existsSync(monthPath)) continue;
      const files = readdirSync(monthPath).filter(f => /^\d{4}-\d{2}-\d{2}\.json$/.test(f));
      for (const file of files) {
        const date = file.replace('.json', '');
        paths.push({ params: { date } });
      }
    }
  }
  return paths;
}

const { date } = Astro.params;
const target = `/free-prediction/jra/${date}/`;
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>移動しました — {target}</title>
  <meta http-equiv="refresh" content={`0; url=${target}`}>
  <link rel="canonical" href={target}>
  <meta name="robots" content="noindex,follow">
  <script is:inline define:vars={{ target }}>
    window.location.replace(target);
  </script>
</head>
<body>
  <p>このページは <a href={target}>{target}</a> に移動しました。</p>
</body>
</html>
