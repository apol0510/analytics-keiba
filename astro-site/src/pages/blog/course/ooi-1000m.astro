        <!-- フッター -->
        <footer style="text-align: center; padding: 25px 0; border-top: 1px solid #e0e0e0; margin-top: 40px; color: #666;">
            <p>© 2024 南関アナリティクス - データで勝つ地方競馬予想</p>
