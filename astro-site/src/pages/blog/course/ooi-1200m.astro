      "dateModified": "2025-09-27",
      "publisher": {
        "@type": "Organization",
        "name": "KEIBA Analytics",
        "logo": {
          "@type": "ImageObject",
          "url": "https://nankan-analytics.keiba.link/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://nankan-analytics.keiba.link/blog/course/ooi-1200m"
      }
    }
    </script>

    <!-- FAQSchema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [{
        "@type": "Question",
        "name": "大井競馬1200mで最も勝率が高い馬番は？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "16番枠が13.6%で最も高い勝率を記録しています。次いで12番枠が11.3%となっています。大外枠の好成績が特徴的です。"
        }
      },{
        "@type": "Question",
        "name": "大井1200mの1番人気の信頼度は？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "1番人気の勝率は40.9%、連対率61.5%、複勝率73.5%と高い信頼度を示しています。"
        }
      }]
    }
    </script>

