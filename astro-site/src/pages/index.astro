<script>
document.addEventListener("DOMContentLoaded",function(){
    function s(t,e,r,i,a=""){
        if(!t||!t.getAttribute)return;
        t.innerHTML="0"+a;
        let l=null;
        const u=g=>{
            l||(l=g);
            const d=Math.min((g-l)/i,1);
            let c;
            try{
                r>=1e3?(c=Math.floor(d*(r-e)+e),t.innerHTML=c.toLocaleString()+a):(c=d*(r-e)+e,t.innerHTML=c.toFixed(1)+a),d<1&&window.requestAnimationFrame(u)
            }catch(f){
                console.error("カウントアップエラー:",f),t.innerHTML=r+a
            }
        };
        window.requestAnimationFrame(u)
    }

    const o=new IntersectionObserver(t=>{
        t.forEach(e=>{
            if(e.isIntersecting&&!e.target.hasAttribute("data-animated")){
                const r=e.target.getAttribute("data-target"),
                      i=e.target.getAttribute("data-suffix")||"";
                if(!r){
                    console.warn("data-target属性が見つかりません:",e.target);
                    return
                }
                const a=parseFloat(r);
                if(isNaN(a)){
                    console.warn("無効なdata-target値:",r);
                    return
                }
                console.log("カウントアップ開始:",a,i),
                s(e.target,0,a,2e3,i),
                e.target.setAttribute("data-animated","true")
            }
        })
    },{threshold:.3});

    const n=document.querySelectorAll(".stats-number");
    console.log("stats-number要素を発見:",n.length);
    n.forEach(t=>{
        const e=t.getAttribute("data-target");
        console.log("要素:",t,"data-target:",e),
        o.observe(t)
    })
});

// メッセージ表示時間の制御
document.addEventListener('DOMContentLoaded', function() {
    const predictionSummary = document.querySelector('.prediction-summary');
    console.log('予想サマリー要素:', predictionSummary);

    if (predictionSummary) {
        const initialMessageEl = predictionSummary.querySelector('.initial-message');
        const actualContentEl = predictionSummary.querySelector('.actual-content');

        console.log('初期メッセージ要素:', initialMessageEl);
        console.log('実際のコンテンツ要素:', actualContentEl);

        if (initialMessageEl && actualContentEl) {
            // 実際のコンテンツがある場合（AI予想完了の文字を含むかチェック）
            const actualText = actualContentEl.innerText.trim();
            console.log('実際のコンテンツ:', actualText);

            if (actualText && (actualText.includes('AI予想完了') || actualText.includes('信頼度') || actualText.length > 50)) {
                console.log('条件一致: 2秒後に切り替え開始');
                // 初期メッセージを表示
                initialMessageEl.style.display = 'block';
                actualContentEl.style.display = 'none';

                // 2秒後に切り替え
                setTimeout(() => {
                    console.log('切り替え実行');
                    initialMessageEl.style.display = 'none';
                    actualContentEl.style.display = 'block';
                }, 2000);
            } else {
                console.log('条件不一致: 初期メッセージのみ表示');
                // 実際のコンテンツがない場合は初期メッセージをそのまま表示
                initialMessageEl.style.display = 'block';
                actualContentEl.style.display = 'none';
            }
        } else {
            console.log('要素が見つかりません');
        }
    } else {
        console.log('.prediction-summary要素が見つかりません');
    }
});
</script>
