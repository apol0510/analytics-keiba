// 静的ビルドのためprerender削除
import BaseLayout from '../layouts/BaseLayout.astro';
import archiveResults from '../data/archiveResults.json';
import archiveResultsJra from '../data/archiveResultsJra.json';
import { weeklyResults, dailyTabs, dailyResultsData } from './standard-predictions.astro';
import { pickLatestAndAdapt, pickLatestJraPrediction } from '../lib/adaptLatestPrediction.js';

// src/data/predictions/*.json（自動反映フロー）から最新日付を自動選択
const predictionModules = import.meta.glob('/src/data/predictions/*.json', { eager: true });
const allRacesData = pickLatestAndAdapt(predictionModules);
if (!allRacesData) {
    throw new Error('予想データが見つかりません。src/data/predictions/ に有効な JSON がありません。');
}

// JRA 予想データ（src/data/predictions/jra/YYYY/MM/*.json）を取得
const jraPredictionModules = import.meta.glob('/src/data/predictions/jra/**/*.json', { eager: true });
const jraLatestPrediction = pickLatestJraPrediction(jraPredictionModules);

// archiveResults.jsonから最新日のデータを取得
// 2026-04-17 以降: 配列形式 (importResults.js v2+ の unshift 順)
function getLatestDayData() {
    if (!Array.isArray(archiveResults) || archiveResults.length === 0) return null;
    const latest = archiveResults[0];
    if (!latest || !latest.date) return null;
    const [year, month, day] = latest.date.split('-');
    return { year, month, day, ...latest };
}

const latestResult = getLatestDayData();

// 昨日の結果データを作成 (新フィールド名: bettingPoints / isHit / umatan.payout / returnRate)
const yesterdayResults = latestResult ? (() => {
    const races = Array.isArray(latestResult.races) ? latestResult.races : [];
    const totalBetPoints = races.reduce((sum, r) => sum + (r.bettingPoints || r.betPoints || 0), 0);
    const jsonRate = latestResult.returnRate ?? latestResult.recoveryRate;
    const fallbackRate = totalBetPoints > 0
        ? Math.round((latestResult.totalPayout / (totalBetPoints * 100)) * 100)
        : 0;
    return {
        date: `${parseInt(latestResult.month)}月${parseInt(latestResult.day)}日`,
        track: latestResult.venue,
        hitCount: latestResult.hitRaces,
        totalCount: latestResult.totalRaces,
        hitRate: latestResult.totalRaces > 0 ? Math.round((latestResult.hitRaces / latestResult.totalRaces) * 100) : 0,
        totalPayout: latestResult.totalPayout,
        totalBetPoints,
        recoveryRate: jsonRate ?? fallbackRate,
        results: races.map(race => ({
            raceNumber: race.raceNumber,
            result: (race.isHit ?? race.hit) ? 'win' : 'lose',
            payout: race.umatan?.payout ?? race.payout ?? 0,
        })),
    };
})() : null;

// JRA 昨日の結果データ
function getLatestJraDayData() {
    if (!Array.isArray(archiveResultsJra) || archiveResultsJra.length === 0) return null;
    const latest = archiveResultsJra[0];
    if (!latest || !latest.date) return null;
    const [year, month, day] = latest.date.split('-');
    return { year, month, day, ...latest };
}

const latestJraResult = getLatestJraDayData();

const yesterdayJraResults = latestJraResult ? (() => {
    const races = Array.isArray(latestJraResult.races) ? latestJraResult.races : [];
    const totalBetPoints = races.reduce((sum, r) => sum + (r.bettingPoints || r.betPoints || 0), 0);
    const jsonRate = latestJraResult.returnRate ?? latestJraResult.recoveryRate;
    const fallbackRate = totalBetPoints > 0
        ? Math.round((latestJraResult.totalPayout / (totalBetPoints * 100)) * 100)
        : 0;
    // venues は文字列配列（例: ['京都','東京','福島']）か単一会場名
    const trackLabel = Array.isArray(latestJraResult.venues) && latestJraResult.venues.length > 0
        ? latestJraResult.venues.join('・')
        : latestJraResult.venue;
    return {
        date: `${parseInt(latestJraResult.month)}月${parseInt(latestJraResult.day)}日`,
        track: trackLabel,
        hitCount: latestJraResult.hitRaces,
        totalCount: latestJraResult.totalRaces,
        hitRate: latestJraResult.totalRaces > 0 ? Math.round((latestJraResult.hitRaces / latestJraResult.totalRaces) * 100) : 0,
        totalPayout: latestJraResult.totalPayout,
        totalBetPoints,
        recoveryRate: jsonRate ?? fallbackRate,
    };
})() : null;

// JRA 本日のプレビュー
const jraPreview = (() => {
    if (!jraLatestPrediction || !Array.isArray(jraLatestPrediction.venues) || jraLatestPrediction.venues.length === 0) {
        return null;
    }
    // メインレース（最終レース or raceNumberが最大）を含む venue を優先選択
    function getMainPt(race) {
        const hs = race?.horses;
        let main = null;
        if (Array.isArray(hs)) main = hs.find(h => h?.role === '本命');
        else if (hs && typeof hs === 'object') main = hs.main;
        return main?.pt ?? main?.confidence ?? 0;
    }
    let pickedVenue = null;
    let pickedRace = null;
    for (const venue of jraLatestPrediction.venues) {
        const preds = Array.isArray(venue?.predictions) ? venue.predictions : [];
        if (preds.length === 0) continue;
        // raceNumber が最大のレースを最終/メインレース候補として選ぶ
        const sorted = [...preds].sort((a, b) => {
            const an = parseInt(String(a.raceInfo?.raceNumber || '0').replace(/\D/g, '')) || 0;
            const bn = parseInt(String(b.raceInfo?.raceNumber || '0').replace(/\D/g, '')) || 0;
            return bn - an;
        });
        const candidate = sorted[0];
        if (!pickedVenue || getMainPt(candidate) > getMainPt(pickedRace)) {
            pickedVenue = venue;
            pickedRace = candidate;
        }
    }
    if (!pickedVenue || !pickedRace) return null;

    const ri = pickedRace.raceInfo || {};
    const rawHorses = pickedRace.horses;

    // horses が list（JRA形式）か dict（南関adapt後形式）かで取り出し方が違う
    let mainHorse = null;
    let subHorse = null;
    if (Array.isArray(rawHorses)) {
        mainHorse = rawHorses.find(h => h?.role === '本命') || null;
        subHorse = rawHorses.find(h => h?.role === '対抗') || null;
    } else if (rawHorses && typeof rawHorses === 'object') {
        mainHorse = rawHorses.main || null;
        subHorse = rawHorses.sub || null;
    }

    const mainName = mainHorse?.horseName || mainHorse?.name || '';
    const subName = subHorse?.horseName || subHorse?.name || '';
    const horseInfo = mainName && subName ? `本命${mainName}・対抗${subName}` : (mainName ? `本命${mainName}` : '');

    // 信頼度: pt（累積スコア）→ confidence、95%上限
    let confidence = 0;
    if (mainHorse?.pt != null) {
        confidence = ptToConfidence(mainHorse.pt);
    } else if (typeof mainHorse?.confidence === 'number') {
        confidence = Math.min(mainHorse.confidence, 95);
    } else if (Array.isArray(mainHorse?.factors)) {
        const factor = mainHorse.factors.find(f => f?.text?.includes?.('累積スコア'));
        const m = factor?.text?.match(/(\d+)pt/);
        if (m) confidence = ptToConfidence(m[1]);
    }

    const venueName = pickedVenue.venue || ri.venue || ri.track || '';
    const dateStr = jraLatestPrediction.date || '';
    const [yyyy, mm, dd] = dateStr.split('-');
    const formatted = (yyyy && mm && dd) ? `${yyyy}年${parseInt(mm)}月${parseInt(dd)}日` : dateStr;
    const title = `${formatted} ${venueName} ${ri.raceNumber || ''}${ri.raceName ? ' ' + ri.raceName : ''}`.trim();

    const teaser = '🔓 本命の選出理由・対抗馬の評価ポイント・特徴量分析・買い目戦略を完全公開中';
    return {
        title,
        confidence,
        summary: `${venueName} ${ri.raceNumber || ''}R AI予想完了！`,
        features: horseInfo
            ? `${horseInfo}\n\n信頼度${confidence}%\n\n${teaser}\n\n🎯 少点数的中型・⚖️ バランス型・🚀 高配当追求型で的中と配当のバランスを最適化。`
            : `信頼度${confidence}%\n\n${teaser}\n\n🎯 少点数的中型・⚖️ バランス型・🚀 高配当追求型で的中と配当のバランスを最適化。`,
    };
})();

// メインレース（11R）のデータを取得 - 防御的プログラミング実装
const mainRace = (allRacesData && Array.isArray(allRacesData.races))
    ? allRacesData.races.find(race => race.isMainRace === true)
    : null;

if (!mainRace) {
    console.error('❌ メインレースデータが見つかりません:', { allRacesData: allRacesData ? 'exists' : 'missing' });
    throw new Error('メインレースデータが見つかりません');
}

const { raceInfo, strategies, horses } = mainRace;

// 戦略データから信頼度を計算
function calculateAverageConfidence(strategies) {
    if (!strategies) return 0;

    const strategyKeys = ['safe', 'balance', 'aggressive'];
    const confidenceValues = strategyKeys
        .map(key => strategies[key]?.confidence || strategies[key]?.hitRate)
        .filter(value => value !== undefined && value !== null)
        .map(value => parseInt(value));

    if (confidenceValues.length === 0) return 0;

    const average = confidenceValues.reduce((sum, val) => sum + val, 0) / confidenceValues.length;
    return Math.round(average);
}

// 累積スコア(pt)を信頼度(%)に変換 — ptは100を超えるため上限95%にクランプ
function ptToConfidence(pt) {
    const n = parseInt(pt);
    if (!Number.isFinite(n) || n <= 0) return 0;
    return Math.min(n, 95);
}

// プレビューコンテンツを生成
function generatePreview(raceInfo, strategies, horses) {
    if (!raceInfo) {
        return {
            summary: 'AIから最新の情報を取得しました！',
            features: ''
        };
    }

    // 本命の累積スコアを信頼度として使用（95%上限）
    let confidence = calculateAverageConfidence(strategies);
    if (horses?.main?.factors) {
        const scoreText = horses.main.factors.find(factor => factor.text && factor.text.includes('累積スコア'));
        if (scoreText) {
            const scoreMatch = scoreText.text.match(/(\d+)pt/);
            if (scoreMatch) {
                confidence = ptToConfidence(scoreMatch[1]);
            }
        }
    }

    const safeTitle = strategies?.safe?.title || '少点数的中型';
    const balanceTitle = strategies?.balance?.title || 'バランス型';
    const aggressiveTitle = strategies?.aggressive?.title || '高配当追求型';

    // 本命・対抗の馬名を取得
    const mainHorseName = horses?.main?.name || '';
    const subHorseName = horses?.sub?.name || '';
    const horseInfo = mainHorseName && subHorseName ? `本命${mainHorseName}・対抗${subHorseName}` : (mainHorseName ? `本命${mainHorseName}` : '');

    const summary = `${raceInfo.track || ''} ${raceInfo.raceNumber || ''} AI予想完了！`.trim();
    const teaser = '🔓 本命の選出理由・対抗馬の評価ポイント・特徴量分析・買い目戦略を完全公開中';
    const features = horseInfo
        ? `${horseInfo}\n\n信頼度${confidence}%\n\n${teaser}\n\n🎯 ${safeTitle}・⚖️ ${balanceTitle}・🚀 ${aggressiveTitle}で的中と配当のバランスを最適化。`
        : `信頼度${confidence}%\n\n${teaser}\n\n🎯 ${safeTitle}・⚖️ ${balanceTitle}・🚀 ${aggressiveTitle}で的中と配当のバランスを最適化。`;

    return { summary, features };
}

// 信頼度計算とプレビュー生成（本命の累積スコアを95%上限でクランプして使用）
let calculatedConfidence = calculateAverageConfidence(strategies);
if (horses?.main?.factors) {
    const scoreText = horses.main.factors.find(factor => factor.text && factor.text.includes('累積スコア'));
    if (scoreText) {
        const scoreMatch = scoreText.text.match(/(\d+)pt/);
        if (scoreMatch) {
            calculatedConfidence = ptToConfidence(scoreMatch[1]);
        }
    }
}
const preview = generatePreview(raceInfo, strategies, horses);

// raceInfoに計算した信頼度を追加
const enhancedRaceInfo = {
    ...raceInfo,
    confidence: calculatedConfidence
};

// 日付と競馬場の情報をallRacesDataから取得（他のページと統一）
const raceDate = allRacesData.raceDate; // "2025-09-18"
const track = allRacesData.track; // "大井競馬"

// 日付を日本語形式に変換（他のページと統一）
const [year, month, day] = raceDate.split('-');
const formattedDate = `${year}年${parseInt(month)}月${parseInt(day)}日`;

// レース情報の整形
const raceTitle = `${formattedDate} ${track} ${enhancedRaceInfo?.raceNumber || ''}${enhancedRaceInfo?.raceName !== 'レース情報未検出' && enhancedRaceInfo?.raceName ? ' ' + enhancedRaceInfo.raceName : ''}`;
