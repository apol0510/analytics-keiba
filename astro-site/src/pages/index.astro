                                <div style="display: inline-block; background: linear-gradient(135deg, #10b981, #059669); color: white; padding: 8px 16px; border-radius: 8px; font-weight: bold; font-size: 0.9rem;">
                                    🏆 {yesterdayResults.hitCount}/{yesterdayResults.totalCount}的中
                                </div>
                            </div>
                        </div>

                        <!-- 的中サマリー -->
                        <div style="display: flex; flex-wrap: wrap; gap: 15px; justify-content: center; margin-bottom: 30px;">
                            <div style="background: rgba(30, 41, 59, 0.8); border: 1px solid rgba(59, 130, 246, 0.3); border-radius: 12px; padding: 15px 25px;">
                                <span style="color: #94a3b8; font-size: 0.9rem;">📊 的中率:</span>
