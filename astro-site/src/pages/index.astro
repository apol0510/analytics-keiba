                            </div>
                            <div style="background: rgba(30, 41, 59, 0.8); border: 1px solid rgba(139, 92, 246, 0.3); border-radius: 12px; padding: 15px 25px;">
                                <span style="color: #94a3b8; font-size: 0.9rem;">📈 回収率:</span>
                                <span style="color: #a78bfa; font-weight: bold; font-size: 1.1rem; margin-left: 8px;">{yesterdayResults.recoveryRate}%</span>
                            </div>
                            <div style="background: rgba(30, 41, 59, 0.8); border: 1px solid rgba(16, 185, 129, 0.3); border-radius: 12px; padding: 15px 25px;">
                                <span style="color: #94a3b8; font-size: 0.9rem;">🎯 合計購入点数:</span>
                                <span style="color: #10b981; font-weight: bold; font-size: 1.1rem; margin-left: 8px;">{yesterdayResults.totalBetPoints}点</span>
                            </div>
                            <div style="background: rgba(30, 41, 59, 0.8); border: 1px solid rgba(245, 158, 11, 0.3); border-radius: 12px; padding: 15px 25px;">
                                <span style="color: #94a3b8; font-size: 0.9rem;">💰 合計配当:</span>
                                <span style="color: #fbbf24; font-weight: bold; font-size: 1.1rem; margin-left: 8px;">¥{yesterdayResults.totalPayout.toLocaleString()}</span>
                            </div>
                        </div>

