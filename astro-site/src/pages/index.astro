                <div class="container" style="max-width: 1200px; margin: 0 auto;">
                    <!-- 大カード -->
                    <div class="results-glass-card results-glass-card--nankan">
                        <div style="text-align: center; margin-bottom: 40px;">
                            <h2 style="font-size: 2.5rem; font-weight: 800; background: linear-gradient(135deg, #10b981 0%, #3b82f6 50%, #8b5cf6 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 15px;">
