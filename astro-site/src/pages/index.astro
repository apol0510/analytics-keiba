                        </div>

                        <!-- Training Data -->
                        <div class="stats-card" style="background: linear-gradient(135deg, rgba(139, 92, 246, 0.15) 0%, rgba(59, 130, 246, 0.15) 100%); padding: 20px 15px; border-radius: 10px; text-align: center; border: 2px solid rgba(139, 92, 246, 0.2); transition: transform 0.3s, box-shadow 0.3s;">
                            <div class="stats-number" data-target="10000" data-suffix="+" style="font-size: 2.2rem; font-weight: 800; color: var(--success-color); margin-bottom: 8px; text-shadow: 0 2px 4px rgba(16, 185, 129, 0.3);">
                                0+
                            </div>
                            <div style="color: var(--body-text-color); font-weight: 600; font-size: 0.95rem; margin-bottom: 5px;">
                                学習データ数
                            </div>
                            <div style="color: var(--accent-text-color); font-size: 0.75rem; line-height: 1.3;">
                                5年間レースデータ
                            </div>
