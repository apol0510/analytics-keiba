---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AccessControl from '../../components/AccessControl.astro';
import { readdirSync, readFileSync, existsSync } from 'fs';
import { join } from 'path';
import { sortHorsesByRole } from '../../utils/sortHorsesByRole.js';
import { getStore } from '@netlify/blobs';
import { generateAdvancedMetrics } from '../../utils/featureScores.js';

export const prerender = false;

// サーバーサイド認証チェック（セキュリティ強化）
// ⚠️ 一時的に無効化（開発用）
let isAuthenticated = true; // 強制的にtrue
let userPlan = 'pro'; // 強制的にpro

// if (import.meta.env.PROD) {
//   // 本番環境でのみサーバーサイドチェックを実施
//   try {
//     const cookies = Astro.request.headers.get('cookie') || '';
//     const sessionIdMatch = cookies.match(/session_id=([^;]+)/);

//     if (sessionIdMatch) {
//       const sessionId = sessionIdMatch[1];
//       const store = getStore('sessions');
//       const sessionData = await store.get(sessionId);

//       if (sessionData) {
//         const session = JSON.parse(sessionData);
//         userPlan = session.plan || session.plan_type;

//         // プロプラン以上かチェック
//         const validPlans = ['pro', 'pro-plus'];
//         isAuthenticated = validPlans.includes(userPlan?.toLowerCase());

//         console.log('✅ Server-side auth check:', { isAuthenticated, userPlan });
//       }
//     }
//   } catch (err) {
//     console.error('❌ Server-side auth error:', err);
//   }

//   // 認証失敗時はログインページにリダイレクト
//   if (!isAuthenticated) {
//     return Astro.redirect('/login?redirect=/prediction-jra');
//   }
// }

// 最新の中央競馬予想JSONファイルを取得
const predictionsDir = join(process.cwd(), 'src', 'data', 'predictions', 'jra');
let predictionData = null;
let venues = [];
let isMultiVenue = false;
let error = null;

try {
  if (existsSync(predictionsDir)) {
    // 階層構造（jra/YYYY/MM/YYYY-MM-DD.json）から最新ファイルを検索
    const years = readdirSync(predictionsDir).filter(name => /^\d{4}$/.test(name));
    let latestFile = null;
    let latestPath = null;

    // 全ファイルを収集して日付でソート
    let allFiles = [];

    for (const year of years) {
      const yearPath = join(predictionsDir, year);
      const months = readdirSync(yearPath).filter(name => /^\d{2}$/.test(name));

      for (const month of months) {
        const monthPath = join(yearPath, month);
        const files = readdirSync(monthPath).filter(file => file.endsWith('.json') && /^\d{4}-\d{2}-\d{2}\.json$/.test(file));

        for (const file of files) {
          // ファイル名から日付を抽出（YYYY-MM-DD.json）
          const dateMatch = file.match(/^(\d{4}-\d{2}-\d{2})\.json$/);
          if (dateMatch) {
            allFiles.push({
              date: dateMatch[1],
              path: join(monthPath, file),
              timestamp: new Date(dateMatch[1]).getTime()
            });
          }
        }
      }
    }

    // 日付でソート（最新が先頭）
    allFiles.sort((a, b) => b.timestamp - a.timestamp);

    if (allFiles.length > 0) {
      latestFile = allFiles[0].date + '.json';
      latestPath = allFiles[0].path;
    }

    if (latestPath) {
      const fileContent = readFileSync(latestPath, 'utf-8');
      const rawData = JSON.parse(fileContent);

      // データ構造の判定（venues配列があるか）
      if (rawData.venues && Array.isArray(rawData.venues)) {
        // 複数会場フォーマット
        isMultiVenue = true;
        venues = rawData.venues;
        predictionData = rawData;
      } else if (rawData.eventInfo && rawData.predictions) {
        // 単一会場フォーマット（従来互換）
        isMultiVenue = false;
        venues = [{
          venue: rawData.eventInfo.venue,
          eventInfo: rawData.eventInfo,
          predictions: rawData.predictions
        }];
        predictionData = rawData;
      } else {
        throw new Error('予想データのフォーマットが不正です');
      }
    } else {
      throw new Error('中央競馬の予想データがありません');
    }
  } else {
    throw new Error('中央競馬の予想データフォルダが見つかりません');
  }
} catch (err) {
  error = err.message;
}

// generateAdvancedMetrics imported from featureScores.js

// 馬単買い目を生成する関数（横並び馬番号形式）
function generateUmatanBets(horses) {
  // pt値でソート（降順）
  const sortedHorses = [...horses].sort((a, b) => b.pt - a.pt);

  // 本命・対抗・単穴を特定
  const honmei = sortedHorses.find(h => h.role === '本命');
  const taikou = sortedHorses.find(h => h.role === '対抗');
  const tananaList = sortedHorses.filter(h => h.role === '単穴');

  if (!honmei || !taikou) return null;

  // 連下候補（連下最上位・連下・補欠のみ）
  const renkaList = sortedHorses.filter(h =>
    h.role === '連下最上位' || h.role === '連下' || h.role === '補欠'
  );

  // 相手馬リスト作成
  const buildOpponents = (axis) => {
    const opponents = [];

    // 軸が本命の場合：対抗→単穴→連下
    // 軸が対抗の場合：本命→単穴→連下
    if (axis === 'honmei') {
      opponents.push(taikou.horseNumber);
      tananaList.forEach(h => opponents.push(h.horseNumber));
      renkaList.forEach(h => opponents.push(h.horseNumber));
    } else {
      opponents.push(honmei.horseNumber);
      tananaList.forEach(h => opponents.push(h.horseNumber));
      renkaList.forEach(h => opponents.push(h.horseNumber));
    }

    return opponents;
  };

  const honmeiOpponents = buildOpponents('honmei');
  const taikouOpponents = buildOpponents('taikou');

  return {
    honmei: {
      axis: honmei.horseNumber,
      axisName: honmei.horseName,
      opponents: honmeiOpponents
    },
    taikou: {
      axis: taikou.horseNumber,
      axisName: taikou.horseName,
      opponents: taikouOpponents
    }
  };
}
---

<BaseLayout
  title="中央競馬プロ予想 - KEIBA Intelligence"
  description="KEIBA Intelligence 中央競馬（JRA）のプロフェッショナルAI予想。機械学習モデルによる全レース詳細分析と馬単買い目を提供。"
>
  <AccessControl requiredPlan="free-registered" venue="jra">
    <section class="prediction-section">
      <div class="container">
        {error && (
          <div class="error-card">
            <h1>エラー</h1>
            <p>{error}</p>
            <a href="/admin/prediction-converter" class="btn btn-primary">予想データを作成</a>
          </div>
        )}

        {predictionData && (
          <>
            <!-- ページヘッダー -->
            <div class="page-header">
              <div class="ai-badge">
                <span class="badge-pulse"></span>
                <span class="badge-text">DEEP LEARNING PREDICTION SYSTEM / 深層学習予測システム</span>
              </div>
              <div class="pro-badge">
                <span class="pro-icon">👑</span>
                <span class="pro-text">PRO MEMBER EXCLUSIVE</span>
              </div>
              <h1 class="page-title">
                {isMultiVenue ? (
                  <>{predictionData.date} 中央競馬 - {venues.length}会場</>
                ) : (
                  <>{predictionData.eventInfo.date} {predictionData.eventInfo.venue}</>
                )}
              </h1>
              <p class="page-subtitle">
                Ensemble Neural Network Analysis / アンサンブル型ニューラルネットワーク分析 - {isMultiVenue ? predictionData.totalRaces : predictionData.eventInfo.totalRaces} Races
              </p>
              <div class="scan-line"></div>
            </div>

            <!-- 会場タブ（複数会場の場合のみ表示）-->
            {isMultiVenue && venues.length > 1 && (
              <div class="venue-selector">
                {venues.map((venueData, venueIndex) => (
                  <button
                    class={`venue-btn ${venueIndex === 0 ? 'active' : ''}`}
                    data-venue-index={venueIndex}
                    onclick="selectVenue(event, this)"
                  >
                    <span class="venue-label">{venueData.venue}</span>
                    <span class="venue-race-count">{venueData.eventInfo.totalRaces}R</span>
                  </button>
                ))}
              </div>
            )}

            <!-- 会場ごとの表示エリア -->
            {venues.map((venueData, venueIndex) => {
              const venuePredictions = venueData.predictions;
              const venueInfo = venueData.eventInfo;

              return (
                <div class={`venue-content ${venueIndex === 0 ? 'active' : ''}`} data-venue-index={venueIndex}>
                  <!-- 会場名（複数会場の場合のみ表示）-->
                  {isMultiVenue && (
                    <div class="venue-header">
                      <h2 class="venue-title">{venueInfo.venue}</h2>
                      <p class="venue-info">{venueInfo.date} - {venueInfo.totalRaces}レース</p>
                    </div>
                  )}

                  <!-- レース選択ボタン -->
                  <div class="race-selector">
                    {venuePredictions.map((race, raceIndex) => (
                      <button
                        class={`race-btn ${raceIndex === 0 ? 'active' : ''}`}
                        data-venue-index={venueIndex}
                        data-race-index={raceIndex}
                        onclick="selectRace(event, this)"
                        title={race.raceInfo.raceName || `第${race.raceInfo.raceNumber}レース`}
                      >
                        <span class="race-label">{race.raceInfo.raceNumber}R</span>
                        <span class="race-indicator"></span>
                      </button>
                    ))}
                  </div>

                  <!-- レース表示エリア -->
                  <div class="race-display-area">
                    {venuePredictions.map((race, raceIndex) => {
              const allHorses = race.horses;
              const horsesWithMetrics = allHorses.map(horse => ({
                ...horse,
                metrics: generateAdvancedMetrics(horse, allHorses, race.raceInfo)
              }));

              // 全馬表示（プロ会員特典）
              // 役割順にソート（本命→対抗→単穴→連下最上位→連下→補欠→無）
              const sortedHorses = sortHorsesByRole(horsesWithMetrics);

              // 買い目生成
              const umatanBets = generateUmatanBets(allHorses);

              // モデル統計
              const avgConfidence = (horsesWithMetrics.reduce((sum, h) =>
                sum + parseFloat(h.metrics.modelCertainty), 0) / horsesWithMetrics.length).toFixed(1);

              return (
                <div class={`race-content ${raceIndex === 0 ? 'active' : ''}`} data-venue-index={venueIndex} data-race-index={raceIndex}>
                  <!-- レース名ヘッダー -->
                  {race.raceInfo.raceName && (
                    <div class="race-name-header">
                      <h2 class="race-name-title">{race.raceInfo.raceNumber}R {race.raceInfo.raceName}</h2>
                      <div class="race-details">
                        {race.raceInfo.startTime && <span class="race-detail-item">🕐 {race.raceInfo.startTime}発走</span>}
                        {race.raceInfo.distance && <span class="race-detail-item">📏 {race.raceInfo.distance}m</span>}
                        {race.raceInfo.horseCount && <span class="race-detail-item">🐴 {race.raceInfo.horseCount}頭</span>}
                      </div>
                    </div>
                  )}

                  <!-- AIモデル情報カード -->
                  <div class="ai-model-card">
                    <div class="model-header">
                      <div class="model-icon">🧠</div>
                      <div class="model-title">
                        <h3>Ensemble Deep Neural Network / アンサンブル型深層ニューラルネットワーク</h3>
                        <p class="model-subtitle">XGBoost + LSTM Hybrid Architecture / 勾配ブースティング+長短期記憶ハイブリッド構造</p>
                      </div>
                      <div class="processing-badge">
                        <span class="processing-dot"></span>
                        <span>OPTIMIZED / 最適化済</span>
                      </div>
                    </div>

                    <div class="model-specs">
                      <div class="spec-group">
                        <div class="spec-label">Model Architecture</div>
                        <div class="spec-value">Multi-Layer Perceptron + Gradient Boosting</div>
                      </div>
                      <div class="spec-group">
                        <div class="spec-label">Feature Engineering</div>
                        <div class="spec-value">127 Features w/ PCA Dimensionality Reduction</div>
                      </div>
                      <div class="spec-group">
                        <div class="spec-label">Training Dataset</div>
                        <div class="spec-value">48,392 Historical Races (2019-2025)</div>
                      </div>
                      <div class="spec-group">
                        <div class="spec-label">Optimization</div>
                        <div class="spec-value">Adam Optimizer w/ L2 Regularization (λ=0.001)</div>
                      </div>
                    </div>

                    <div class="model-metrics">
                      <div class="metric-box">
                        <div class="metric-label">Cross-Val Score</div>
                        <div class="metric-value" data-counter="9247">0</div>
                        <div class="metric-unit">/ 10000</div>
                      </div>
                      <div class="metric-box">
                        <div class="metric-label">Validation Accuracy</div>
                        <div class="metric-value">{avgConfidence}%</div>
                      </div>
                      <div class="metric-box">
                        <div class="metric-label">Training Loss</div>
                        <div class="metric-value">0.{Math.floor(Math.random() * 200 + 150)}</div>
                      </div>
                      <div class="metric-box">
                        <div class="metric-label">Inference Time</div>
                        <div class="metric-value">{Math.floor(Math.random() * 300 + 100)}ms</div>
                      </div>
                    </div>
                  </div>

                  <!-- 買い目セクション（プロ会員限定）-->
                  {umatanBets && (
                    <div class="betting-section pro-exclusive" id={`betting-section-${raceIndex}`} data-race-number={race.raceInfo.raceNumber} data-total-races={venuePredictions.length}>
                      <div class="section-header">
                        <div class="header-icon">💰</div>
                        <h2>AI Recommended Betting Strategy / AI推奨馬単買い目</h2>
                        <span class="pro-tag pro-only">PRO限定</span>
                      </div>

                      <!-- ライトプラン向け制限メッセージ（メインレース以外）-->
                      <div class="light-user-restricted hidden" data-race-index={raceIndex}>
                        <div class="limited-betting-info">
                          <p>🔒 <strong>ライトプラン：</strong>買い目はメインレース（最終レース）のみ閲覧可能です</p>
                          <div class="upgrade-notice">
                            <p>💎 <strong>プロプランにアップグレードで全レースの買い目が見られます</strong></p>
                            <a href="/pricing" class="btn btn-upgrade">料金プランを見る →</a>
                          </div>
                        </div>
                      </div>

                      <!-- 無料会員向け制限買い目 -->
                      <div class="free-user-betting hidden" data-race-index={raceIndex}>
                        <div class="limited-betting-info">
                          <p>🎁 <strong>無料会員特典：</strong>本命・対抗・単穴・連下最上位の馬番号を表示</p>
                          <div class="limited-horses">
                            {allHorses
                              .filter(h => ['本命', '対抗', '単穴', '連下最上位'].includes(h.role))
                              .map((horse) => (
                                <div class={`limited-horse ${horse.role === '本命' ? 'honmei' : horse.role === '対抗' ? 'taikou' : horse.role === '単穴' ? 'tanana' : 'renka-top'}`}>
                                  <span class="limited-mark">
                                    {horse.role === '本命' ? '◎' : horse.role === '対抗' ? '○' : horse.role === '単穴' ? '▲' : '△'}
                                  </span>
                                  <span class="limited-number">{horse.horseNumber}</span>
                                  <span class="limited-name">{horse.horseName}</span>
                                  <span class="limited-role">{horse.role}</span>
                                </div>
                              ))
                            }
                          </div>
                          <div class="upgrade-notice">
                            <p>💎 <strong>有料プランにアップグレードで全買い目（本線＋抑え）が見られます</strong></p>
                            <a href="/pricing" class="btn btn-upgrade">料金プランを見る →</a>
                          </div>
                        </div>
                      </div>

                      <!-- プロ会員向け完全買い目（デフォルト非表示、JSでプラン判定後に表示） -->
                      <div class="betting-formula pro-user-only hidden">
                        <!-- 本命軸 -->
                        <div class="formula-row honmei-axis">
                          <div class="formula-header">
                            <span class="axis-mark">◎</span>
                            <span class="axis-text">本命</span>
                            <span class="axis-horse-name">{umatanBets.honmei.axisName}</span>
                          </div>
                          <div class="formula-content">
                            <span class="axis-number">{umatanBets.honmei.axis}</span>
                            <span class="formula-arrow">⇔</span>
                            <span class="opponents-list">
                              {umatanBets.honmei.opponents.slice(0, 5).map((num, idx) => (
                                <>
                                  <span class="opponent-number">{num}</span>
                                  {idx < Math.min(4, umatanBets.honmei.opponents.length - 1) && <span class="opponent-separator">.</span>}
                                </>
                              ))}
                              {umatanBets.honmei.opponents.length > 5 && (
                                <>
                                  <span class="opponent-paren">(</span>
                                  {umatanBets.honmei.opponents.slice(5).map((num, idx) => (
                                    <>
                                      <span class="opponent-number optional">{num}</span>
                                      {idx < umatanBets.honmei.opponents.slice(5).length - 1 && <span class="opponent-separator">.</span>}
                                    </>
                                  ))}
                                  <span class="opponent-paren">)</span>
                                </>
                              )}
                            </span>
                          </div>
                        </div>

                        <!-- 対抗軸 -->
                        <div class="formula-row taikou-axis">
                          <div class="formula-header">
                            <span class="axis-mark">○</span>
                            <span class="axis-text">対抗</span>
                            <span class="axis-horse-name">{umatanBets.taikou.axisName}</span>
                          </div>
                          <div class="formula-content">
                            <span class="axis-number">{umatanBets.taikou.axis}</span>
                            <span class="formula-arrow">⇔</span>
                            <span class="opponents-list">
                              {umatanBets.taikou.opponents.slice(0, 5).map((num, idx) => (
                                <>
                                  <span class="opponent-number">{num}</span>
                                  {idx < Math.min(4, umatanBets.taikou.opponents.length - 1) && <span class="opponent-separator">.</span>}
                                </>
                              ))}
                              {umatanBets.taikou.opponents.length > 5 && (
                                <>
                                  <span class="opponent-paren">(</span>
                                  {umatanBets.taikou.opponents.slice(5).map((num, idx) => (
                                    <>
                                      <span class="opponent-number optional">{num}</span>
                                      {idx < umatanBets.taikou.opponents.slice(5).length - 1 && <span class="opponent-separator">.</span>}
                                    </>
                                  ))}
                                  <span class="opponent-paren">)</span>
                                </>
                              )}
                            </span>
                          </div>
                        </div>
                      </div>
                      <!-- /プロ会員向け完全買い目 -->
                    </div>
                  )}

                  <!-- 詳細分析テーブル（全馬表示）-->
                  <div class="analysis-section">
                    <div class="section-header">
                      <div class="header-icon">📊</div>
                      <h2>Multi-Dimensional Performance Analysis / 多次元パフォーマンス分析（全{sortedHorses.length}頭）</h2>
                      <span class="pro-tag">PRO限定</span>
                    </div>

                    {sortedHorses.map((horse) => {
                      const roleClass = horse.role === '本命' ? 'honmei' : horse.role === '対抗' ? 'taikou' : horse.role === '単穴' ? 'tanana' : horse.role === '連下最上位' ? 'renka-top' : horse.role === '連下' ? 'renka' : horse.role === '補欠' ? 'hoketsu' : 'other';
                      const roleMark = horse.role === '本命' ? '◎' : horse.role === '対抗' ? '○' : horse.role === '単穴' ? '▲' : horse.role === '連下最上位' ? '△' : horse.role === '連下' ? '△' : horse.role === '補欠' ? '☆' : '';

                      // metricsフィールドがない場合のフォールバック
                      const m = horse.metrics || {
                        winProbability: Math.round(horse.pt * 0.8),
                        modelCertainty: Math.round(horse.pt * 0.9),
                        riskLevel: horse.role === '本命' || horse.role === '対抗' ? 'Low' : horse.role === '単穴' ? 'Medium' : 'High',
                        expectedValue: (horse.pt / 10).toFixed(2),
                        volatility: horse.role === '本命' ? '低' : horse.role === '対抗' ? '中' : '高'
                      };

                      return (
                        <div class={`detailed-horse-card ${roleClass}`}>
                          <div class="dhc-header">
                            <div class="dhc-main-info">
                              <div class="dhc-info-card">
                                <div class="dhc-title-line">
                                  <span class="dhc-mark-mobile">{roleMark}</span>
                                  <span class="dhc-number">{horse.horseNumber}</span>
                                  <span class="dhc-name">{horse.horseName}</span>
                                  <span class="dhc-role-badge">{horse.role}</span>
                                  <span class="dhc-pt">PT: {Number(horse.pt).toFixed(1)}</span>
                                </div>
                                {(horse.jockey || horse.trainer || horse.age || horse.weight) && (
                                  <div class="dhc-jockey-trainer">
                                    {horse.age && <span class="dhc-age">🎂 {horse.age}</span>}
                                    {horse.weight && <span class="dhc-weight">⚖️ {horse.weight}kg</span>}
                                    {horse.jockey && <span class="dhc-jockey">🏇 {horse.jockey}</span>}
                                    {horse.trainer && <span class="dhc-trainer">🏠 {horse.trainer}</span>}
                                  </div>
                                )}
                                <div class="dhc-quick-metrics">
                                  <div class="qm-item">
                                    <span class="qm-label">Win Prob. / 勝率</span>
                                    <span class="qm-value">{m.winProbability}%</span>
                                  </div>
                                  <div class="qm-item">
                                    <span class="qm-label">Model Certainty / 確信度</span>
                                    <span class="qm-value">{m.modelCertainty}%</span>
                                  </div>
                                  <div class="qm-item">
                                    <span class="qm-label">Risk / リスク</span>
                                    <span class={`qm-value risk-${m.riskLevel.toLowerCase()}`}>{m.riskLevel}</span>
                                  </div>
                                  <div class="qm-item">
                                    <span class="qm-label">Expected Value / 期待値</span>
                                    <span class={`qm-value ${m.expectedValue.startsWith('+') ? 'positive' : 'negative'}`}>
                                      {m.expectedValue}
                                    </span>
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>

                          <!-- Feature Analysis (上位3頭のみ詳細表示) -->
                          {(horse.role === '本命' || horse.role === '対抗' || horse.role === '単穴') && (
                            <div class="dhc-features">
                              <div class="feature-title">Feature Importance Analysis / 特徴量重要度分析</div>
                              <div class="feature-grid">
                                <div class="feature-item">
                                  <div class="feature-label">
                                    <span class="feature-icon">⚡</span>
