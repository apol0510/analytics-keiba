  <script is:inline>
    function selectVenue(event, button) {
      event.preventDefault();

      const venueIndex = button.getAttribute('data-venue-index');

      // 会場タブの切り替え
      document.querySelectorAll('.venue-btn').forEach(btn => {
        btn.classList.remove('active');
      });
      button.classList.add('active');

      // 会場コンテンツの切り替え
      document.querySelectorAll('.venue-content').forEach(content => {
        content.classList.remove('active');
      });

      const selectedVenue = document.querySelector(`.venue-content[data-venue-index="${venueIndex}"]`);
      if (selectedVenue) {
        selectedVenue.classList.add('active');

        // カウンターアニメーション（アクティブなレースのみ）
        const activeRace = selectedVenue.querySelector('.race-content.active');
        if (activeRace) {
          activeRace.querySelectorAll('[data-counter]').forEach(el => {
            const target = parseInt(el.getAttribute('data-counter'));
            animateCounter(el, target);
          });
        }
      }

      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function selectRace(event, button) {
      event.preventDefault();

      const venueIndex = button.getAttribute('data-venue-index');
      const raceIndex = button.getAttribute('data-race-index');

      // 現在の会場内のレースボタンのみ更新
      const currentVenue = document.querySelector(`.venue-content[data-venue-index="${venueIndex}"]`);
      if (!currentVenue) return;

      currentVenue.querySelectorAll('.race-btn').forEach(btn => {
        btn.classList.remove('active');
      });
      button.classList.add('active');

      // 現在の会場内のレースコンテンツのみ更新
      currentVenue.querySelectorAll('.race-content').forEach(content => {
        content.classList.remove('active');
      });

      const selectedRace = currentVenue.querySelector(`.race-content[data-venue-index="${venueIndex}"][data-race-index="${raceIndex}"]`);
      if (selectedRace) {
        selectedRace.classList.add('active');

        selectedRace.querySelectorAll('[data-counter]').forEach(el => {
          const target = parseInt(el.getAttribute('data-counter'));
          animateCounter(el, target);
        });
      }
    }

    function animateCounter(element, target) {
      const duration = 1500;
      const start = 0;
      const startTime = Date.now();

      function update() {
        const now = Date.now();
        const progress = Math.min((now - startTime) / duration, 1);
        const easeProgress = 1 - Math.pow(1 - progress, 3);
        const current = Math.floor(easeProgress * target);
        element.textContent = current.toLocaleString();

        if (progress < 1) {
          requestAnimationFrame(update);
        }
      }

      update();
    }

    document.addEventListener('DOMContentLoaded', () => {
      const activeRace = document.querySelector('.race-content.active');
      if (activeRace) {
        activeRace.querySelectorAll('[data-counter]').forEach(el => {
          const target = parseInt(el.getAttribute('data-counter'));
          animateCounter(el, target);
        });
      }

      // ユーザータイプチェック
      const isFreeUser = sessionStorage.getItem('isFreeUser') === 'true';
      const isLightUser = sessionStorage.getItem('isLightUser') === 'true';
      console.log('🔍 ユーザータイプ:', isFreeUser ? '無料会員' : isLightUser ? 'ライト会員' : 'プロ会員');

      if (isFreeUser) {
        // 無料ユーザー向け表示
        document.querySelectorAll('.free-user-betting').forEach(el => {
          el.classList.remove('hidden');
        });
        document.querySelectorAll('.betting-formula.pro-user-only').forEach(el => {
          el.classList.add('hidden');
        });
        document.querySelectorAll('.light-user-restricted').forEach(el => {
          el.classList.add('hidden');
        });
        document.querySelectorAll('.pro-tag.pro-only').forEach(el => {
          el.textContent = '無料会員';
          el.style.background = 'linear-gradient(135deg, #10b981 0%, #059669 100%)';
        });
      } else if (isLightUser) {
        // ライトユーザー向け表示（メインレースのみ買い目表示）
        document.querySelectorAll('.betting-section.pro-exclusive').forEach(section => {
          const raceNumber = parseInt(section.dataset.raceNumber);
          const totalRaces = parseInt(section.dataset.totalRaces);
          const isMainRace = raceNumber === totalRaces; // 最終レースがメイン

          if (isMainRace) {
            // メインレース：プロと同じ買い目を表示
            section.querySelector('.betting-formula.pro-user-only')?.classList.remove('hidden');
            section.querySelector('.free-user-betting')?.classList.add('hidden');
            section.querySelector('.light-user-restricted')?.classList.add('hidden');
          } else {
            // メインレース以外：制限メッセージを表示
            section.querySelector('.betting-formula.pro-user-only')?.classList.add('hidden');
            section.querySelector('.free-user-betting')?.classList.add('hidden');
            section.querySelector('.light-user-restricted')?.classList.remove('hidden');
          }
        });
        document.querySelectorAll('.pro-tag.pro-only').forEach(el => {
          el.textContent = 'LIGHT';
          el.style.background = 'linear-gradient(135deg, #8b5cf6 0%, #6d28d9 100%)';
        });
      } else {
        // プロユーザー向け表示
        document.querySelectorAll('.free-user-betting').forEach(el => {
          el.classList.add('hidden');
        });
        document.querySelectorAll('.light-user-restricted').forEach(el => {
          el.classList.add('hidden');
        });
        document.querySelectorAll('.betting-formula.pro-user-only').forEach(el => {
          el.classList.remove('hidden');
        });
      }
    });
  </script>
